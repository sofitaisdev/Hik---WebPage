  // ── OBTENER ROL (varias estrategias) ─────────────────────────────────
  async function fetchRole(email, userToken) {
    // Estrategia 1: con token del usuario autenticado
    try {
      setLoginStep('Verificando permisos...');
      var authH = { apikey: SB_KEY, Authorization: 'Bearer ' + userToken, 'Content-Type': 'application/json' };
      var res = await fetch(
        SB_URL + '/rest/v1/usuarios?email=eq.' + encodeURIComponent(email) + '&select=rol&limit=1',
        { headers: authH }
      );
      if (res.ok) {
        var rows = await res.json();
        console.log('[ROL] Estrategia 1 (auth token):', JSON.stringify(rows));
        if (Array.isArray(rows) && rows.length > 0 && rows[0].rol) {
          return String(rows[0].rol).toLowerCase();
        }
      } else {
        console.warn('[ROL] Estrategia 1 falló con status:', res.status);
      }
    } catch(e) {
      console.warn('[ROL] Estrategia 1 excepción:', e.message);
    }

    // Estrategia 2: con clave anon
    try {
      var res2 = await fetch(
        SB_URL + '/rest/v1/usuarios?email=eq.' + encodeURIComponent(email) + '&select=rol&limit=1',
        { headers: H }
      );
      if (res2.ok) {
        var rows2 = await res2.json();
        console.log('[ROL] Estrategia 2 (anon key):', JSON.stringify(rows2));
        if (Array.isArray(rows2) && rows2.length > 0 && rows2[0].rol) {
          return String(rows2[0].rol).toLowerCase();
        }
      } else {
        console.warn('[ROL] Estrategia 2 falló con status:', res2.status);
      }
    } catch(e) {
      console.warn('[ROL] Estrategia 2 excepción:', e.message);
    }

    // Estrategia 3: user_metadata de Supabase Auth (si el rol se guarda ahí)
    try {
      if (sbClient) {
        var { data: userData } = await sbClient.auth.getUser(userToken);
        if (userData && userData.user && userData.user.user_metadata && userData.user.user_metadata.rol) {
          var rolMeta = String(userData.user.user_metadata.rol).toLowerCase();
          console.log('[ROL] Estrategia 3 (user_metadata):', rolMeta);
          return rolMeta;
        }
      }
    } catch(e) {
      console.warn('[ROL] Estrategia 3 excepción:', e.message);
    }

    console.warn('[ROL] No se pudo obtener el rol, usando guest');
    return 'guest';
  }

  // ── LOGIN ────────────────────────────────────────────────────────────
  document.getElementById('btn-login').addEventListener('click', async function() {
    var email = document.getElementById('login-email').value.trim().toLowerCase();
    var pass  = document.getElementById('login-pass').value;

    hideLoginAlert();

    if (!email || !pass) {
      showLoginAlert('Completá email y contraseña.');
      return;
    }

    var btn = this;
    btn.textContent = 'Ingresando...';
    btn.disabled = true;

    // Verificar que Supabase esté disponible
    if (!sbClient && !initSupabase()) {
      showLoginAlert('Error: no se pudo conectar con el servidor. Recargá la página.');
      resetLoginBtn();
      return;
    }

    try {
      setLoginStep('Verificando credenciales...');

      var authResult = await sbClient.auth.signInWithPassword({ email: email, password: pass });
      console.log('[LOGIN] auth error:', authResult.error ? authResult.error.message : 'ninguno');

      if (authResult.error) {
        var errMsg = authResult.error.message || '';
        // Traducir mensajes comunes de Supabase
        if (errMsg.includes('Invalid login credentials') || errMsg.includes('invalid_credentials')) {
          showLoginAlert('Email o contraseña incorrectos.');
        } else if (errMsg.includes('Email not confirmed')) {
          showLoginAlert('Debés confirmar tu email antes de iniciar sesión.');
        } else if (errMsg.includes('Too many requests')) {
          showLoginAlert('Demasiados intentos. Esperá unos minutos.');
        } else {
          showLoginAlert('Error: ' + errMsg);
        }
        setLoginStep('');
        resetLoginBtn();
        return;
      }

      // Auth exitosa
      var session = authResult.data.session;
      if (!session) {
        showLoginAlert('Error al obtener la sesión. Intentá de nuevo.');
        setLoginStep('');
        resetLoginBtn();
        return;
      }

      var userToken = session.access_token;
      currentRole = await fetchRole(email, userToken);
      console.log('[LOGIN] Rol final:', currentRole);

      setLoginStep('');
      launchApp(email);

    } catch(e) {
      console.error('[LOGIN] Excepción inesperada:', e);
      showLoginAlert('Error de conexión: ' + (e.message || 'desconocido'));
      setLoginStep('');
      resetLoginBtn();
    }
  });

