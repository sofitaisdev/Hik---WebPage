 "All-in-One Series", "Cabinet", "Online UPS", "Adapter", "Eyepiece", "Rail", "Battery Chargers", "Interchangeable Batteries", "Lenses", "IR Torch", "IR Torch Bracket", "Battery", "Pouches", "Ring", "CV-Accessory Series", "Charger", "Monocular Monitor Screen", "Solar Panel", "Binocular Harness", "Monocular Pouch", "AX HYBRID PRO G2 Series", "Remote Controller", "Full Height Turnstile", "Swing Gate", "Spare parts", "ESD Solutions", "Sliding gate opener", "Detectors", "Digital Video Recorders", "Entrance & Exit Control Terminals", "Entrance & Exit Controllers", "Parking Indicators", "On-Street Parking Cameras", "All-in-One Entrance & Exit Manager", "Parking Terminal", "Payment Machines", "Geomagnetic Management System", "Sliding Gate Motor", "Tire Spike Strip", "Entrance & Exit Signal Light", "Wall-mounted AC Charging Station", "Portable AC Charger", "All-in-one DC Charging Station", "HF-Link Series", "Metal Detectors", "X-Ray Screening", "Addressable FAS", "360 AVM System", "Commercial Display Accessories", "Rental LED", "LED module for First Vision", "Indoor Module", "Aries Series", "Flex Series", "54\" LED Splicing Screen", "LED AIO", "LumiFit Series", "LumiSquare Series", "LED Poster", "LumiValue Series", "Outdoor Module", "Normal LED Module for Outdoor Series", "Flexible Module", "Solid Plus Series", "LumiUltra Series", "Wi-Fi Router", "4G\\5G Router", "Wall Mount AP", "Celling AP", "Outdoor AP", "Smart Managed Router", "Wi-Fi Extender", "Wi-Fi Adapter", "Gaming Monitor", "Class Board", "Blackboard Series", "Water Level & Flow Radar", "Imaging Radar", "Level Meter Radar", "Obstacle Avoidance Radar", "Industrial Radar Terminal", "Performance Series", "Select Series", "Conference Series", "Intelligent security analyzer", "Maintenance Accessories of Security Inspection System", "Liquid Detection Equipment", "Security Inspection of peripheral products", "Millimeter Wave Person Security Inspection System", "Gas Leakage Monitoring", "Analog Speaker", "Amplifier", "Pro Speakers", "Positioning product", "Independent Series", "Smoke Series", "Heat Series", "Flame Series", "Conventional FAS", "Muti-Sensor Series", "Fiber Optic Sensing", "Pyrometer", "Media Server", "Paging Microphone", "Audio Kit", "Audio Processor", "Mixer Console", "Pro Microphone", "Public Address Accessories", "Public Address and Voice Alarm system", "Pro Amplifier", "Visible Audio", "Server Others", "Electric Vehicle Charging Station Accessories", "iVMS-5200 ANPR System", "iVMS-5200 Professional", "iVMS-5200 Mobile Surveillance", "HikCentral Professional", "HikCentral Master", "HikCentral Enterprise", "HikCentral iVisual", "HikCentral Optimus", "HikCentral Lite", "Parking Management Software", "Hik-Partner Pro(Hik-ProConnect)", "Hik-Connect", "HikCentral Connect"];

        const tbody = document.getElementById('tabla-body');
        const pageInfo = document.getElementById('page-info');
        const btnPrev = document.getElementById('prev-page');
        const btnNext = document.getElementById('next-page');
        const fSerie = document.getElementById('f-serie');
        const fMarca = document.getElementById('f-marca');
        const fLinea = document.getElementById('f-linea');
        const searchInput = document.getElementById('buscador');

        let page = 0;
        const size = 15;

        const formatP = (v) => {
            const num = parseFloat(v);
            return (num > 0) ? `$${num.toLocaleString('en-US', { minimumFractionDigits: 2 })}` : `<span class="no-price">-</span>`;
        };

        function buildQuery() {
            let q = _supabase.from('productos').select('*', { count: 'exact' }).not('modelo', 'is', null).neq('modelo', '');
            
            if (searchInput instanceof HTMLInputElement && searchInput.value) {
                const t = searchInput.value.trim();
                q = q.or(`modelo.ilike.%${t}%,sap.ilike.%${t}%`);
            }
            if (fMarca instanceof HTMLSelectElement && fMarca.value) q = q.eq('marca', fMarca.value);
            if (fLinea instanceof HTMLSelectElement && fLinea.value) q = q.eq('linea', fLinea.value);
            if (fSerie instanceof HTMLSelectElement && fSerie.value) q = q.eq('serie', fSerie.value);
            
            return q;
        }

        async function load() {
            const { data, count, error } = await buildQuery().order('modelo', { ascending: true }).range(page * size, (page * size) + size - 1);
            
            if (error) { console.error("Error Supabase:", error); return; }
            if (data && tbody) {
                tbody.innerHTML = data.map(p => `
                    <tr>
                        <td class="col-mod">${p.modelo}</td>
                        <td><img class="img-prod" src="https://wmubdrjqailnizfyxsft.supabase.co/storage/v1/object/public/Fotos%20-%20Productos/${p.sap}.jpg" onerror="this.src='https://placehold.co/45x45?text=N/A'"></td>
                        <td>${p.marca || '-'}</td>
                        <td>${p.linea || '-'}</td>
                        <td>${p.serie || '-'}</td>
                        <td class="col-tech">${p.carac_tecnicas || '-'}</td>
                        <td class="p-vta">${formatP(p.price_diamond)}</td>
                        <td class="p-vta">${formatP(p.price_black)}</td>
                        <td class="p-vta">${formatP(p.price_platinum)}</td>
                        <td class="p-vta">${formatP(p.price_ruby)}</td>
                        <td class="p-vta">${formatP(p.price_gold)}</td>
                        <td class="p-vta">${formatP(p.fob_bdm)}</td>
                        <td class="p-vta">${formatP(p.proy_bdm)}</td>
                        <td class="p-vta">${formatP(p.fob_dir)}</td>
                        <td class="p-vta">${formatP(p.proy_dir)}</td>
                        <td>${p.ciclo_de_vida || '-'}</td>
                        <td style="font-weight:bold;">${p.sap || '-'}</td>
                    </tr>
                `).join('');

                const total = count || 0;
                if (pageInfo) pageInfo.innerText = `Mostrando ${(page * size) + 1} - ${Math.min((page * size) + size, total)} de ${total}`;
                if (btnPrev instanceof HTMLButtonElement) btnPrev.disabled = page === 0;
                if (btnNext instanceof HTMLButtonElement) btnNext.disabled = ((page * size) + size) >= total;
            }
        }

        function initFilters() {
            // Llenar Marca
            if (fMarca instanceof HTMLSelectElement) {
                fMarca.innerHTML = '<option value="">Todas las Marcas</option>' + 
                    MARCAS_MASTER.sort().map(m => `<option value="${m}">${m}</option>`).join('');
            }
            // Llenar Línea
            if (fLinea instanceof HTMLSelectElement) {
                fLinea.innerHTML = '<option value="">Todas las Líneas</option>' + 
                    LINEAS_MASTER.sort().map(l => `<option value="${l}">${l}</option>`).join('');
            }
            // Llenar Serie
            if (fSerie instanceof HTMLSelectElement) {
                const sorted = [...new Set(SERIES_MASTER)].sort();
                fSerie.innerHTML = '<option value="">Todas las Series</option>' + 
                    sorted.map(s => `<option value="${s}">${s}</option>`).join('');
            }
        }

        const resetAndLoad = () => { page = 0; load(); };

        if (searchInput) searchInput.addEventListener('input', resetAndLoad);
        [fMarca, fLinea, fSerie].forEach(el => {
            if (el) el.addEventListener('change', resetAndLoad);
        });

        if (btnPrev) btnPrev.addEventListener('click', () => { if (page > 0) { page--; load(); } });
        if (btnNext) btnNext.addEventListener('click', () => { page++; load(); });

        initFilters();
        load();
    </script>
</body>
</html>