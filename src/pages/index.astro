function formatPrice(val, cls) {
  if (val === undefined || val === null || val === '') return "<span class='price p-zero'>-</span>";
  var s = String(val).trim();
  if (!s || s === '-' || s === '0') return "<span class='price p-zero'>-</span>";
  if (/^(ARS|USD|EUR)\s+/i.test(s)) {
    return "<span class='price " + cls + "'>" + s + "</span>";
  }
  var clean = s.replace(/[^0-9.,]/g, '');
  if (clean === '') return "<span class='price p-zero'>-</span>";
  var n;
  if (clean.indexOf('.') !== -1 && clean.indexOf(',') !== -1) {
    clean = clean.replace(/\./g, '').replace(',', '.');
  } else if (clean.indexOf(',') !== -1) {
    var parts = clean.split(',');
    if (parts[1] && parts[1].length <= 2) { clean = clean.replace(',', '.'); }
    else { clean = clean.replace(/,/g, ''); }
  } else if (clean.indexOf('.') !== -1) {
    var dotParts = clean.split('.');
    if (dotParts.length > 2) { clean = clean.replace(/\./g, ''); }
    else if (dotParts[dotParts.length - 1].length === 3) { clean = clean.replace(/\./g, ''); }
  }
  n = parseFloat(clean);
  if (isNaN(n) || n <= 0) return "<span class='price p-zero'>-</span>";
  var formatted = n.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return "<span class='price " + cls + "'>$" + formatted + "</span>";
}

/* ══════════════════════════════════════════════════════
   makeImageCell — imagen siempre contenida en 48×48 px
══════════════════════════════════════════════════════ */
function makeImageCell(val){
  var d=document.createElement('div');
  d.className='img-cell';
  var url=val?String(val).trim():'';
  if(!url||url==='null'||url==='undefined'||url.length<5){
    var ph=document.createElement('div');ph.className='img-placeholder';ph.textContent='Sin foto';d.appendChild(ph);return d;
  }
  var img=document.createElement('img');
  img.className='img-thumb';
  /* Atributos HTML explícitos: el navegador reserva el espacio ANTES de cargar */
  img.setAttribute('width','48');
  img.setAttribute('height','48');
  img.src=url;img.alt='';img.loading='lazy';
  img.addEventListener('click',function(){document.getElementById('lightbox-img').src=url;document.getElementById('lightbox').classList.add('active');});
  img.addEventListener('error',function(){
    d.innerHTML='';
    var ph=document.createElement('div');ph.className='img-placeholder';ph.textContent='Sin foto';d.appendChild(ph);
  });
  d.appendChild(img);return d;
}

function makeCell(content,flex,alignLeft,isFunciones){
  var d=document.createElement('div');
  var jc=alignLeft?'flex-start':'center';var ta=alignLeft?'left':'center';
  d.style.cssText='flex:'+flex+';min-width:0;display:flex;align-items:'+(isFunciones?'flex-start':'center')+';justify-content:'+jc+';text-align:'+ta+';padding:5px 4px;font-size:.72rem;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;';
  if(isFunciones){var inner=document.createElement('div');inner.className='func-cell';inner.textContent=typeof content==='string'?content:'';d.appendChild(inner);}
  else{if(typeof content==='string'){d.innerHTML=content;}else{d.appendChild(content);}}
  return d;
}

function render(){
  var body=document.getElementById('table-body');body.innerHTML='';
  if(!currentData.length){body.innerHTML='<div style="text-align:center;padding:48px;color:#aaa;">No se encontraron productos.</div>';return;}
  var cols=getVisibleColumns();
  var minW=cols.reduce(function(a,c){return a+c.flex;},0)*88;
  var frag=document.createDocumentFragment();
  currentData.forEach(function(p){
    var row=document.createElement('div');
    row.className='tbl-row';
    /* overflow:hidden en la fila es la segunda línea de defensa contra imágenes grandes */
    row.style.cssText='display:flex;width:100%;min-width:'+minW+'px;border-bottom:1px solid #e8e8e8;height:56px;max-height:56px;overflow:hidden;align-items:center;';
    cols.forEach(function(col){
      var val=p[col.field];
      if(col.image){row.appendChild(makeImageCell(val));return;}
      if(col.price){
        var html=(val===undefined||val===null||val==='')?
          "<span class='price p-zero'>-</span>":formatPrice(val,col.cls);
        row.appendChild(makeCell(html,col.flex,false,false));return;
      }
      var isFunciones=(col.field==='funciones');
      var txt=(val===undefined||val===null||val==='')?'-':(String(val).trim()||'-');
      if(!isFunciones&&txt.length>140)txt=txt.substring(0,140)+'...';
      row.appendChild(makeCell(txt,col.flex,!!col.alignLeft,isFunciones));
    });
    frag.appendChild(row);
  });
  body.appendChild(frag);
}

function paginate(){
  var pages=Math.ceil(totalCount/PAGE_SIZE);var pag=document.getElementById('pagination');
  if(pages<=1){pag.innerHTML="<span class='page-info'>"+totalCount+" productos</span>";return;}
  var h="<button class='page-btn' id='pp'"+(currentPage===1?' disabled':'')+">Anterior</button>";
  for(var i=1;i<=pages;i++){
    if(i===1||i===pages||Math.abs(i-currentPage)<=2)h+="<button class='page-btn"+(i===currentPage?' active':'')+"' data-p='"+i+"'>"+i+"</button>";
    else if(Math.abs(i-currentPage)===3)h+="<span class='page-info'>...</span>";
  }
  h+="<button class='page-btn' id='pn'"+(currentPage===pages?' disabled':'')+">Siguiente</button>";
  h+="<span class='page-info'>Pag "+currentPage+"/"+pages+" - "+totalCount+" productos</span>";
  pag.innerHTML=h;
  var pp=document.getElementById('pp');if(pp)pp.addEventListener('click',function(){doSearch(currentPage-1);});
  var pn=document.getElementById('pn');if(pn)pn.addEventListener('click',function(){doSearch(currentPage+1);});
  pag.querySelectorAll('[data-p]').forEach(function(b){b.addEventListener('click',function(){doSearch(+b.dataset.p);});});
}

document.getElementById('btn-export').addEventListener('click',function(e){
  e.stopPropagation();var p=document.getElementById('dd-export-panel');closeAll();p.classList.toggle('open');
});

document.getElementById('exp-excel').addEventListener('click',async function(){
  showToast('Preparando Excel...','update');
  var rows=applyFilters();var cols=getVisibleColumns().filter(function(c){return !c.image;});
  var data=rows.map(function(p){var obj={};cols.forEach(function(c){obj[c.label]=p[c.field]!==undefined?p[c.field]:'';});return obj;});
  var ws=XLSX.utils.json_to_sheet(data);var wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Productos');XLSX.writeFile(wb,'catalogo_hikvision.xlsx');closeAll();
});

document.getElementById('exp-csv').addEventListener('click',async function(){
  showToast('Preparando CSV...','update');
  var rows=applyFilters();var cols=getVisibleColumns().filter(function(c){return !c.image;});
  var data=rows.map(function(p){var obj={};cols.forEach(function(c){obj[c.label]=p[c.field]!==undefined?p[c.field]:'';});return obj;});
  if(data.length){
    var keys=cols.map(function(c){return c.label;});
    var csv=keys.join(',')+'\n'+data.map(function(r){return keys.map(function(k){var v=String(r[k]||'');return(v.indexOf(',')!==-1||v.indexOf('"')!==-1)?'"'+v.replace(/"/g,'""')+'"':v;}).join(',');}).join('\n');
    var a=document.createElement('a');a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'}));a.download='catalogo_hikvision.csv';a.click();
  }
  closeAll();
});

document.getElementById('lightbox').addEventListener('click',function(){this.classList.remove('active');});
document.getElementById('lightbox-close').addEventListener('click',function(e){e.stopPropagation();document.getElementById('lightbox').classList.remove('active');});


function handleFile(file){
  var ext=file.name.split('.').pop().toLowerCase();
  dz.querySelector('p').textContent='📄 '+file.name+' ('+Math.round(file.size/1024)+' KB)';
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var data=e.target.result;var wb,ws,rows;
      if(ext==='csv'){var text=new TextDecoder('utf-8').decode(new Uint8Array(data));if(text.charCodeAt(0)===0xFEFF)text=text.slice(1);wb=XLSX.read(text,{type:'string'});}
      else{wb=XLSX.read(data,{type:'array'});}
      ws=wb.Sheets[wb.SheetNames[0]];rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      if(rows.length<2){alert('El archivo está vacío o tiene solo encabezados.');return;}
      parsedHeaders=rows[0].map(function(h){return String(h).trim();});
      importRows=rows.slice(1).map(function(r){var obj={};parsedHeaders.forEach(function(h,i){obj[h]=r[i]!==undefined?String(r[i]).trim():'';});return obj;}).filter(function(r){return Object.values(r).some(function(v){return v!=='';});});
      buildColumnMapping();
    }catch(err){alert('Error al leer el archivo: '+err.message);}
  };
  reader.readAsArrayBuffer(file);
}

var SAP_ALIASES=['sap','sap_code','sap code','cod_sap','codigo sap','código sap','codigos_sap','sap_codigo'];
var FOTO_ALIASES=['foto','foto_url','foto url','image_url','cloudinary_url','url_foto','imagen_url','url_imagen','image','url'];
var FUNC_ALIASES=['funciones','functional description','func','descripcion','descripción','functions','functional_description','description','desc'];

function autoDetect(aliases){var lower=parsedHeaders.map(function(h){return h.toLowerCase();});for(var i=0;i<aliases.length;i++){var idx=lower.indexOf(aliases[i].toLowerCase());if(idx!==-1)return parsedHeaders[idx];}return '';}

function buildColumnMapping(){
  var mapSap=document.getElementById('map-sap');var mapFoto=document.getElementById('map-foto');var mapFunc=document.getElementById('map-func');
  var opts='<option value="">-- No mapear --</option>'+parsedHeaders.map(function(h){return '<option value="'+h.replace(/"/g,'&quot;')+'">'+h+'</option>';}).join('');
  mapSap.innerHTML=opts.replace('<option value="">-- No mapear --</option>','<option value="">-- Seleccionar --</option>');
  mapFoto.innerHTML=opts;mapFunc.innerHTML=opts;
  var autoSap=autoDetect(SAP_ALIASES),autoFoto=autoDetect(FOTO_ALIASES),autoFunc=autoDetect(FUNC_ALIASES);
  if(autoSap)mapSap.value=autoSap;if(autoFoto)mapFoto.value=autoFoto;if(autoFunc)mapFunc.value=autoFunc;
  document.getElementById('step-map').style.display='block';
  [mapSap,mapFoto,mapFunc].forEach(function(s){s.addEventListener('change',buildPreview);});
  document.getElementById('chk-foto').addEventListener('change',buildPreview);
  document.getElementById('chk-func').addEventListener('change',buildPreview);
  buildPreview();
}

function buildPreview(){
  var sapCol=document.getElementById('map-sap').value;var fotoCol=document.getElementById('map-foto').value;var funcCol=document.getElementById('map-func').value;
  var wantFoto=document.getElementById('chk-foto').checked;var wantFunc=document.getElementById('chk-func').checked;
  if(!sapCol){document.getElementById('step-preview').style.display='none';document.getElementById('btn-run-import').disabled=true;return;}
  var withFoto=0,withFunc=0,skip=0;
  var previewData=importRows.map(function(r){
    var sap=String(r[sapCol]||'').trim();if(!sap){skip++;return null;}
    var foto=wantFoto&&fotoCol?String(r[fotoCol]||'').trim():'';var func=wantFunc&&funcCol?String(r[funcCol]||'').trim():'';
    if(foto)withFoto++;if(func)withFunc++;return{sap:sap,foto_url:foto,funciones:func};
  }).filter(Boolean);
  var statsHtml='<span class="stat-pill stat-total">'+previewData.length+' filas</span>';
  if(wantFoto&&fotoCol)statsHtml+='<span class="stat-pill stat-foto">'+withFoto+' con foto_url</span>';
  if(wantFunc&&funcCol)statsHtml+='<span class="stat-pill stat-func">'+withFunc+' con funciones</span>';
  if(skip)statsHtml+='<span class="stat-pill stat-skip">'+skip+' sin SAP (se omiten)</span>';
  document.getElementById('preview-stats').innerHTML=statsHtml;
  var cols=['SAP'];if(wantFoto&&fotoCol)cols.push('foto');if(wantFunc&&funcCol)cols.push('funciones');
  var tbl='<thead><tr>'+cols.map(function(c){return'<th>'+c+'</th>';}).join('')+'</tr></thead><tbody>';
  previewData.slice(0,50).forEach(function(r){
    tbl+='<tr><td>'+r.sap+'</td>';
    if(wantFoto&&fotoCol)tbl+='<td title="'+r.foto_url+'">'+truncStr(r.foto_url,60)+'</td>';
    if(wantFunc&&funcCol)tbl+='<td title="'+r.funciones+'">'+truncStr(r.funciones,80)+'</td>';
    tbl+='</tr>';
  });
  if(previewData.length>50)tbl+='<tr><td colspan="'+cols.length+'" style="text-align:center;color:#888;padding:8px;">... y '+(previewData.length-50)+' filas más</td></tr>';
  tbl+='</tbody>';
  document.getElementById('preview-table').innerHTML=tbl;
  document.getElementById('step-preview').style.display='block';
  document.getElementById('btn-run-import').disabled=!(previewData.length>0&&((wantFoto&&fotoCol)||(wantFunc&&funcCol)));
}

function truncStr(s,n){s=s||'';return s.length>n?s.substring(0,n)+'…':s;}

function addLog(msg,type){
  var log=document.getElementById('import-log');log.classList.add('active');
  var span=document.createElement('div');span.className='log-'+(type||'info');span.textContent=msg;log.appendChild(span);log.scrollTop=log.scrollHeight;
}

document.getElementById('btn-run-import').addEventListener('click',async function(){
  var sapCol=document.getElementById('map-sap').value;var fotoCol=document.getElementById('map-foto').value;var funcCol=document.getElementById('map-func').value;
  var wantFoto=document.getElementById('chk-foto').checked&&!!fotoCol;var wantFunc=document.getElementById('chk-func').checked&&!!funcCol;
  var overwrite=document.getElementById('chk-overwrite').checked;
  if(!sapCol)return;
  if(!sessionToken){alert('Necesitás estar logueado con una cuenta para importar.');return;}
  var rows=importRows.map(function(r){
    var sap=String(r[sapCol]||'').trim();if(!sap)return null;
    var obj={sap:sap};if(wantFoto)obj.foto_url=String(r[fotoCol]||'').trim();if(wantFunc)obj.funciones=String(r[funcCol]||'').trim();return obj;
  }).filter(Boolean);
  if(!rows.length)return;
  var btn=this;btn.disabled=true;document.getElementById('import-btn-label').textContent='Importando...';
  document.getElementById('import-progress').style.display='block';document.getElementById('import-log').innerHTML='';
  addLog('Iniciando importación de '+rows.length+' filas...','info');
  var ok=0,skipped=0,errors=0;
  var authHeaders={apikey:SB_KEY,Authorization:'Bearer '+sessionToken,'Content-Type':'application/json','Prefer':'return=minimal'};
  for(var i=0;i<rows.length;i++){
    var r=rows[i];var patch={};
    if(wantFoto&&r.foto_url){patch.foto=r.foto_url;}if(wantFunc&&r.funciones){patch.funciones=r.funciones;}
    if(!overwrite){
      var existing=allData.find(function(p){return String(p.sap||'').trim()===r.sap;});
      if(existing){
        var hasFoto=existing.foto&&String(existing.foto).trim().length>5;
        var hasFunc=existing.funciones&&String(existing.funciones).trim().length>3;
        var filtered={};
        if(wantFoto&&r.foto_url&&!hasFoto)filtered.foto_url=r.foto_url;
        if(wantFunc&&r.funciones&&!hasFunc)filtered.funciones=r.funciones;
        if(Object.keys(filtered).length===0){skipped++;continue;}
        patch=filtered;
      }
    }
    if(Object.keys(patch).length===0){skipped++;continue;}
    try{
      var res=await fetch(SB_URL+'/rest/v1/productos?sap=eq.'+encodeURIComponent(r.sap),{method:'PATCH',headers:authHeaders,body:JSON.stringify(patch)});
      if(res.ok||res.status===204){
        ok++;
        allData.forEach(function(p){if(String(p.sap||'').trim()===r.sap){if(patch.foto)p.foto=patch.foto;if(patch.funciones)p.funciones=patch.funciones;}});
        if(ok<=10||ok%50===0)addLog('✓ '+r.sap+' actualizado','ok');
      }else{var errTxt='';try{errTxt=await res.text();}catch(e){}errors++;addLog('✗ '+r.sap+' — Error '+res.status+': '+errTxt.substring(0,120),'err');}
    }catch(e){errors++;addLog('✗ '+r.sap+' — '+e.message,'err');}
    var pct=Math.round(((i+1)/rows.length)*100);
    document.getElementById('prog-fill').style.width=pct+'%';
    document.getElementById('prog-label').textContent='Procesando '+(i+1)+'/'+rows.length+' — ✓ '+ok+' actualizados · '+skipped+' omitidos · '+errors+' errores';
    if(i%20===0)await new Promise(function(r){setTimeout(r,0);});
  }
  addLog('─────────────────────────────────','info');
  addLog('Finalizado: '+ok+' actualizados · '+skipped+' omitidos · '+errors+' errores','ok');
  document.getElementById('prog-label').textContent='Completado: '+ok+' actualizados · '+skipped+' omitidos · '+errors+' errores';
  document.getElementById('import-btn-label').textContent='✓ Importación completada';
  showToast(ok+' productos actualizados en Supabase','');
  doSearch(currentPage);
});

async function start(){
  try{
    var res=await Promise.all([fetchAllProducts(),fetchPricebook()]);
    var products=res[0],pbMap=res[1];allData=products;
    if(Object.keys(pbMap).length){allData.forEach(function(p){if(!p.funciones||String(p.funciones).trim()===''){var sap=String(p.sap||'').trim();if(sap&&pbMap[sap])p.funciones=pbMap[sap];}});}
    buildDropdownValues();
    buildDropdown('marca','Todas las marcas');buildDropdown('linea','Todas las lineas');buildDropdown('serie','Todas las series');
    doSearch(1);document.getElementById('loading-bar').classList.remove('active');
    /* Badge: tabla conectada a la base de datos */
    document.getElementById('rt-badge').className='rt-badge connected';
    document.getElementById('rt-label').textContent='Conectado';
  }catch(err){
    console.error(err);document.getElementById('loading-msg').textContent='Error: '+err.message;
    document.getElementById('rt-badge').className='rt-badge disconnected';
    document.getElementById('rt-label').textContent='Sin conexión';
  }
}

window.addEventListener('load',function(){initSupabase();});
