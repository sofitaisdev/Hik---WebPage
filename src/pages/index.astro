  return allData.filter(function(p){
    if(ma.length&&ma.indexOf(p.marca)===-1)return false;
    if(li.length&&li.indexOf(p.linea)===-1)return false;
    if(se.length&&se.indexOf(p.serie)===-1)return false;
    if(q){var hay=[p.modelo,p.funciones,p.sku_codigo,p.sap,p.sku_base].map(function(v){return v?String(v).toLowerCase():'';}).join(' ');if(hay.indexOf(q)===-1)return false;}
    return true;
  });
}

