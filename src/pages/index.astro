async function fetchPricebook() {
  if (!PRICEBOOK_URL) return {};
  try {
    var res = await fetch(PRICEBOOK_URL, { cache: 'no-store' }); if (!res.ok) return {};
    var buf = await res.arrayBuffer(); var wb = XLSX.read(buf, { type: 'array' });
    var ws = wb.Sheets[wb.SheetNames[0]]; var rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
    var header = rows[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var sapIdx = header.indexOf('sap code'), funcIdx = header.indexOf('functional description');
    if (sapIdx === -1 || funcIdx === -1) return {};
    var map = {};
    for (var i = 1; i < rows.length; i++) {
      var sap = String(rows[i][sapIdx]).trim(), func = String(rows[i][funcIdx]).trim();
      if (sap && func && func !== 'undefined') map[sap] = func;
    }
    return map;
  } catch(e) { return {}; }
}

async function fetchAllProducts() {
  var msgEl = document.getElementById('loading-msg'); var all = [], offset = 0, page = 1;
  while (true) {
    if (msgEl) msgEl.textContent = 'Cargando... página ' + page + ' (' + all.length + ' productos)';
    var from = offset, to = offset + SB_PAGE - 1; var authTok = sessionToken || SB_KEY;
    var res = await fetch(SB_URL + '/rest/v1/productos?select=*', {
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + authTok, 'Content-Type': 'application/json',
        'Range-Unit': 'items', 'Range': from + '-' + to, 'Prefer': 'count=exact' }, cache: 'no-store' });
    if (!res.ok) { var eb = ''; try { eb = await res.text(); } catch(e) {} throw new Error('API ' + res.status + (eb ? ': ' + eb.substring(0,200) : '')); }
    var rows = await res.json(); if (!Array.isArray(rows)) rows = [];
    var cr = res.headers.get('content-range') || ''; var tm = cr.match(/\/(\d+)$/); var serverTotal = tm ? parseInt(tm[1], 10) : null;
    all = all.concat(rows);
    if (msgEl && serverTotal) msgEl.textContent = 'Cargando... ' + all.length + ' / ' + serverTotal + ' productos';
    if (rows.length < SB_PAGE) break; if (serverTotal !== null && all.length >= serverTotal) break;
    offset += SB_PAGE; page++;
    await new Promise(function(r) { setTimeout(r, 50); });
  }
  all.forEach(function(p) { p._score = completenessScore(p); });
  all.sort(function(a, b) { return b._score - a._score; });
  return all;
}

/* ================================================================
   FILTERS
================================================================ */
function applyFilters() {
  var q = document.getElementById('search').value.trim().toLowerCase();
  return allData.filter(function(p) {
    for (var i = 0; i < FILTER_KEYS.length; i++) {
      var k = FILTER_KEYS[i];
      var sel = Object.keys(filterState[k]);
      if (sel.length && sel.indexOf(p[k]) === -1) return false;
    }
    if (q) {
      var hay = [p.modelo, p.funciones, p.sku_codigo, p.sap, p.sku_base, p.marca]
        .map(function(v) { return v ? String(v).toLowerCase() : ''; }).join(' ');
      if (hay.indexOf(q) === -1) return false;
    }
    return true;
  });
}

function doSearch(page) {
  currentPage = page || 1;
  document.getElementById('search-spinner').classList.add('active');
  var filtered = applyFilters(); totalCount = filtered.length;
  var off = (currentPage - 1) * PAGE_SIZE; currentData = filtered.slice(off, off + PAGE_SIZE);
  render(); paginate();
  document.getElementById('search-spinner').classList.remove('active');
}

document.getElementById('search').addEventListener('input', function() {
  clearTimeout(debounceTimer); debounceTimer = setTimeout(function() { doSearch(1); }, 200);
});

function buildDropdownValues() {
  FILTER_KEYS.forEach(function(k) {
    dropdownValues[k] = [...new Set(allData.map(function(r) { return r[k]; }).filter(Boolean))]
      .sort(function(a, b) { return a.localeCompare(b); });
  });
}

function buildDropdown(id, defaultLabel) {
  var btn   = document.getElementById('dd-' + id + '-btn');
  var panel = document.getElementById('dd-' + id + '-panel');
  var list  = document.getElementById('dd-' + id + '-list');
  var si    = document.getElementById('dd-' + id + '-search');
  var cl    = document.getElementById('dd-' + id + '-clear');
  var cnt   = document.getElementById('dd-' + id + '-count');

  function renderList(q) {
    q = (q || '').toLowerCase();
    var fl = dropdownValues[id].filter(function(v) { return !q || String(v).toLowerCase().indexOf(q) !== -1; });
    list.innerHTML = fl.map(function(v, i) {
      return '<div class="cb-panel-item"><input type="checkbox" id="cb-' + id + '-' + i + '" value="' + String(v).replace(/'/g, "&#39;") + '" ' + (filterState[id][v] ? 'checked' : '') + '/><label for="cb-' + id + '-' + i + '">' + v + '</label></div>';
    }).join('') || '<div style="padding:8px 12px;color:#aaa;">Sin resultados</div>';
    list.querySelectorAll('input[type=checkbox]').forEach(function(cb) {
      cb.addEventListener('change', function() {
        if (cb.checked) filterState[id][cb.value] = true; else delete filterState[id][cb.value];
        updateLabel(); doSearch(1);
      });
    });
  }
  function updateLabel() {
    var sel = Object.keys(filterState[id]);
    btn.textContent = sel.length === 0 ? defaultLabel : sel.length === 1 ? sel[0] : sel.length + ' seleccionados';
    cnt.textContent = sel.length ? sel.length + ' selec.' : '';
  }
  btn.addEventListener('click', function(e) {
    e.stopPropagation(); closeAll(); panel.classList.toggle('open');
    if (panel.classList.contains('open')) { renderList(''); si.value = ''; si.focus(); }
  });
  si.addEventListener('input', function() { renderList(si.value); });
  cl.addEventListener('click', function() { filterState[id] = {}; updateLabel(); renderList(si.value); doSearch(1); });
}

