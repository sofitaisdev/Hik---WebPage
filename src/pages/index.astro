<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Catálogo Hikvision - Precios por Rol</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.7/dist/umd/supabase.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --burg: #800000; --burg-dark: #5a0000;
      --cream: #f5f5f5; --border: #e0e0e0; --text: #1a1a1a; --text-muted: #888;
    }
    html, body { height: 100%; }
    body { font-family: "Inter", sans-serif; background: var(--cream); color: var(--text); display: flex; flex-direction: column; overflow: hidden; }

    /* ── LOGIN ── */
    #login-overlay { position: fixed; inset: 0; background: #f0f0f0; z-index: 9999; display: flex; align-items: center; justify-content: center; }
    .login-card { background: white; border-radius: 16px; padding: 44px 36px; width: 390px; max-width: calc(100vw - 32px); box-shadow: 0 8px 48px rgba(0,0,0,.12); text-align: center; border-top: 4px solid var(--burg); }
    .login-card img { height: 44px; margin: 0 auto 20px; display: block; }
    .login-card h2 { font-size: 1rem; font-weight: 700; color: var(--burg); margin-bottom: 4px; }
    .login-card p { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 22px; }
    .login-alert { display: none; padding: 9px 12px; border-radius: 7px; font-size: 0.82rem; font-weight: 500; margin-bottom: 12px; }
    .login-alert.err  { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .login-alert.warn { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
    .login-alert.ok   { background: #f0faf4; color: #1a7a3c; border: 1px solid #b8e8cc; }
    .login-step { font-size: 0.78rem; color: #888; min-height: 18px; margin-bottom: 6px; }
    .login-input { width: 100%; padding: 10px 13px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 0.9rem; font-family: inherit; outline: none; margin-bottom: 10px; }
    .login-input:focus { border-color: var(--burg); }
    .login-btn { width: 100%; padding: 11px; background: var(--burg); color: white; border: none; border-radius: 9px; font-size: 0.9rem; font-weight: 700; cursor: pointer; font-family: inherit; margin-bottom: 14px; }
    .login-btn:hover:not(:disabled) { background: var(--burg-dark); }
    .login-btn:disabled { opacity: .55; cursor: not-allowed; }
    .login-sep { border: none; border-top: 1px solid #eee; margin: 4px 0 14px; }
    .guest-btn { width: 100%; padding: 9px; background: transparent; color: #888; border: 1px solid #ddd; border-radius: 9px; font-size: 0.82rem; cursor: pointer; font-family: inherit; }
    .guest-btn:hover { border-color: var(--burg); color: var(--burg); }

    /* ── ROLE PILLS ── */
    .role-pill { font-size: 0.7rem; font-weight: 700; padding: 2px 9px; border-radius: 20px; text-transform: uppercase; letter-spacing: .08em; flex-shrink: 0; }
    .role-diamond { background: #dbeafe; color: #1d4ed8; }
    .role-black   { background: #1a1a1a; color: #fff; }
    .role-platino { background: #ede9fe; color: #6d28d9; }
    .role-ruby    { background: #ffe4e6; color: #be123c; }
    .role-gold    { background: #fef3c7; color: #92400e; }
    .role-guest   { background: #f3f4f6; color: #6b7280; }

    /* ── HEADER ── */
    .header { background: #fff; padding: 10px 32px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; box-shadow: 0 3px 12px rgba(0,0,0,.10); border-bottom: 2px solid var(--burg); flex-shrink: 0; }
    .logo-wrapper { display: flex; align-items: center; }
    .header-title { color: var(--burg); font-weight: 700; font-size: 0.9rem; letter-spacing: .15em; text-transform: uppercase; position: absolute; left: 50%; transform: translateX(-50%); }
    .header-right { display: flex; align-items: center; gap: 10px; }
    .usr-badge { font-size: 0.75rem; color: #666; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .logout-btn { display: none; padding: 5px 12px; background: white; border: 1px solid #ddd; border-radius: 6px; font-size: 0.78rem; cursor: pointer; color: #666; }
    .logout-btn:hover { border-color: var(--burg); color: var(--burg); }
    .rt-badge { display:flex; align-items:center; gap:6px; font-size:.72rem; color:#555; padding:4px 10px; border-radius:20px; border:1px solid var(--border); background:#fafafa; }
    .rt-badge.connected   { color:#1a7a3c; border-color:#b8e8cc; background:#f0faf4; }
    .rt-badge.connecting  { color:#a07010; border-color:#f0d890; background:#fffbec; }
    .rt-badge.disconnected{ color:#cc3333; border-color:#f5c0c0; background:#fff5f5; }
    .rt-dot { width:8px; height:8px; border-radius:50%; background:#ccc; flex-shrink:0; }
    .rt-badge.connected .rt-dot    { background:#1a7a3c; }
    .rt-badge.connecting .rt-dot   { background:#c09020; }
    .rt-badge.disconnected .rt-dot { background:#cc3333; }

    /* ── TOASTS ── */
    .toast-container { position:fixed; bottom:24px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; pointer-events:none; }
    .toast { padding:10px 16px; border-radius:8px; font-size:.82rem; font-weight:500; color:white; background:#1a7a3c; box-shadow:0 4px 16px rgba(0,0,0,.2); transform:translateX(120%); transition:transform .3s; pointer-events:none; }
    .toast.show   { transform:translateX(0); }
    .toast.update { background:#1a5a9a; }
    .toast.error  { background:#8a2020; }

    /* ── TOOLBAR ── */
    .toolbar { background:white; padding:8px 32px; border-bottom:1px solid var(--border); flex-shrink:0; }
    .toolbar-inner { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
    .search-wrap { flex:0 0 30%; position:relative; min-width:200px; }
    .search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); }
    .search-spinner { position:absolute; right:10px; top:50%; transform:translateY(-50%); display:none; }
    .search-spinner.active { display:block; }
    .search-input { width:100%; padding:9px 36px 9px 38px; font-size:.88rem; font-family:inherit; border:1.5px solid var(--border); border-radius:6px; outline:none; background:#fafafa; }
    .search-input:focus { border-color:var(--burg); background:white; }
    .cb-dropdown { position:relative; flex:1; min-width:140px; }
    .cb-dropdown-btn { width:100%; padding:9px 30px 9px 12px; border:1.5px solid var(--border); border-radius:6px; font-size:.85rem; font-family:inherit; cursor:pointer; background:#fafafa; text-align:left; }
    .cb-dropdown-btn:hover { border-color:var(--burg); }
    .cb-dropdown-panel { display:none; position:absolute; top:calc(100% + 2px); left:0; min-width:100%; max-width:300px; background:white; border:1.5px solid var(--burg); border-radius:6px; z-index:300; }
    .cb-dropdown-panel.open { display:block; }
    .cb-panel-search { padding:8px; border-bottom:1px solid var(--border); }
    .cb-panel-search input { width:100%; padding:5px 9px; border:1px solid var(--border); border-radius:5px; font-size:.82rem; }
    .cb-panel-list { max-height:240px; overflow-y:auto; padding:4px 0; }
    .cb-panel-item { display:flex; align-items:center; gap:8px; padding:6px 12px; cursor:pointer; font-size:.84rem; }
    .cb-panel-item:hover { background:#fdf0f0; }
    .cb-panel-item input[type="checkbox"] { accent-color:var(--burg); width:14px; height:14px; }
    .cb-panel-footer { padding:5px 12px 7px; border-top:1px solid var(--border); display:flex; justify-content:space-between; }
    .cb-count-label { font-size:.75rem; color:var(--text-muted); }
    .cb-clear-btn { font-size:.78rem; color:var(--burg); background:none; border:none; cursor:pointer; font-weight:700; }
    .btn-green { padding:9px 16px; font-size:.85rem; font-weight:700; border-radius:6px; cursor:pointer; border:none; background:#1a7a3c; color:white; display:flex; align-items:center; gap:6px; white-space:nowrap; }
    .btn-green:hover { background:#145c2c; }

    /* ── STATUS ── */
    .status-bar { padding:3px 32px; background:#fff8f8; border-bottom:1px solid var(--border); min-height:22px; flex-shrink:0; }
    .loading-bar { display:none; align-items:center; gap:8px; color:var(--burg); font-size:.83rem; font-weight:500; }
    .loading-bar.active { display:flex; }
    .spinner { width:14px; height:14px; border:2.5px solid #f0d0d0; border-top-color:var(--burg); border-radius:50%; animation:spin .7s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg) } }

    /* ── TABLE ── */
    main { padding:10px 32px 6px; overflow-x:auto; flex:1; display:flex; flex-direction:column; min-height:0; }
    .card { background:white; border-radius:10px; box-shadow:0 2px 16px rgba(0,0,0,.08); overflow:hidden; display:flex; flex-direction:column; flex:1; min-height:0; }
    .tbl-wrap { overflow-x:auto; overflow-y:auto; width:100%; flex:1; min-height:0; }
    .tbl-head, .tbl-row { display:flex; flex-direction:row; align-items:stretch; width:100%; }
    .tbl-head { background:linear-gradient(90deg,var(--burg-dark),var(--burg)); position:sticky; top:0; z-index:10; }
    .tbl-row { border-bottom:1px solid var(--border); }
    .tbl-row:nth-child(even) { background:#fafafa; }
    .tbl-row:hover { background:#fff0f0; }

    /* ── PRICE STYLES ── */
    .price { font-weight:700!important; font-size:.82rem; text-align:center; }
    .p-diamond { color:#2b7fd4; }
    .p-black   { color:#111; }
    .p-plat    { color:#7070a0; }
    .p-ruby    { color:#be123c; }
    .p-gold    { color:#b8860b; }
    .p-goldplus{ color:#c07000; }
    .p-map     { color:#065f46; }
    .p-zero    { color:#ccc; font-weight:400!important; }

    /* ── PAGINATION ── */
    .pagination { display:flex; align-items:center; justify-content:center; gap:6px; padding:7px; background:white; border-top:1px solid var(--border); flex-wrap:wrap; flex-shrink:0; }
    .page-btn { padding:5px 11px; border:1.5px solid var(--border); border-radius:5px; background:white; cursor:pointer; font-size:.83rem; }
    .page-btn:hover, .page-btn.active { background:var(--burg); color:white; border-color:var(--burg); }
    .page-btn:disabled { opacity:.3; cursor:not-allowed; }
    .page-info { color:var(--text-muted); font-size:.82rem; }

    /* ── LIGHTBOX ── */
    .lightbox { display:none; position:fixed; inset:0; background:rgba(0,0,0,.85); z-index:1000; align-items:center; justify-content:center; }
    .lightbox.active { display:flex; }
    .lightbox img { max-width:70vw; max-height:70vh; object-fit:contain; border-radius:10px; }
    .lightbox-close { position:absolute; top:18px; right:24px; color:white; font-size:2.2rem; cursor:pointer; }

    /* ── INFO FOOTER ── */
    .info-text { font-size:0.75rem; color:#444; margin-bottom:2px; }

    /* ── LOCK ICON FOR RESTRICTED COLUMNS ── */
    .col-locked { opacity:.45; }
    .lock-icon { font-size:.65rem; vertical-align:middle; margin-left:2px; }
  </style>
</head>
<body>

<!-- ════════════════════════════ LOGIN ════════════════════════════ -->
<div id="login-overlay">
  <div class="login-card">
    <img src="https://res.cloudinary.com/dmmj4nmxp/image/upload/v1771907606/Captura_de_pantalla_2026-02-23_232840_m1jg3p.png" alt="Hikvision" onerror="this.style.display='none'" />
    <h2>Catálogo de Productos</h2>
    <p>Iniciá sesión para ver tus precios</p>
    <div id="login-alert" class="login-alert"></div>
    <div class="login-step" id="login-step"></div>
    <input id="login-email" class="login-input" type="email" placeholder="Email" autocomplete="email" />
    <input id="login-pass"  class="login-input" type="password" placeholder="Contraseña" autocomplete="current-password" />
    <button id="btn-login" class="login-btn">Ingresar</button>
    <hr class="login-sep" />
    <button id="btn-guest" class="guest-btn">Continuar como invitado (solo precios MAP)</button>
  </div>
</div>

<!-- ════════════════════════════ APP ════════════════════════════ -->
<div id="app" style="display:none;flex-direction:column;height:100%;overflow:hidden;">

  <header class="header">
    <div class="logo-wrapper">
      <img src="https://res.cloudinary.com/dmmj4nmxp/image/upload/v1771907606/Captura_de_pantalla_2026-02-23_232840_m1jg3p.png" style="height:38px;width:auto;" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <div class="header-title">Catálogo de Productos</div>
    <div class="header-right">
      <span id="usr-badge" class="usr-badge"></span>
      <span id="role-pill" class="role-pill role-guest" style="display:none;"></span>
      <button id="btn-logout" class="logout-btn">Cerrar sesión</button>
      <div id="rt-badge" class="rt-badge connecting">
        <span class="rt-dot"></span>
        <span id="rt-label">Conectando...</span>
      </div>
    </div>
  </header>

  <div class="toolbar">
    <div class="toolbar-inner">
      <div class="search-wrap">
        <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input class="search-input" id="search" type="text" placeholder="Buscar modelo, SKU, SAP, funciones..." />
        <div class="search-spinner" id="search-spinner"><div class="spinner"></div></div>
      </div>
      <div class="cb-dropdown" id="dd-marca">
        <button class="cb-dropdown-btn" id="dd-marca-btn">Todas las marcas</button>
        <div class="cb-dropdown-panel" id="dd-marca-panel">
          <div class="cb-panel-search"><input type="text" id="dd-marca-search" placeholder="Buscar marca..." /></div>
          <div class="cb-panel-list" id="dd-marca-list"></div>
          <div class="cb-panel-footer"><span class="cb-count-label" id="dd-marca-count"></span><button class="cb-clear-btn" id="dd-marca-clear">Limpiar</button></div>
        </div>
      </div>
      <div class="cb-dropdown" id="dd-linea">
        <button class="cb-dropdown-btn" id="dd-linea-btn">Todas las líneas</button>
        <div class="cb-dropdown-panel" id="dd-linea-panel">
          <div class="cb-panel-search"><input type="text" id="dd-linea-search" placeholder="Buscar línea..." /></div>
          <div class="cb-panel-list" id="dd-linea-list"></div>
          <div class="cb-panel-footer"><span class="cb-count-label" id="dd-linea-count"></span><button class="cb-clear-btn" id="dd-linea-clear">Limpiar</button></div>
        </div>
      </div>
      <div class="cb-dropdown" id="dd-serie">
        <button class="cb-dropdown-btn" id="dd-serie-btn">Todas las series</button>
        <div class="cb-dropdown-panel" id="dd-serie-panel">
          <div class="cb-panel-search"><input type="text" id="dd-serie-search" placeholder="Buscar serie..." /></div>
          <div class="cb-panel-list" id="dd-serie-list"></div>
          <div class="cb-panel-footer"><span class="cb-count-label" id="dd-serie-count"></span><button class="cb-clear-btn" id="dd-serie-clear">Limpiar</button></div>
        </div>
      </div>
      <div class="cb-dropdown" id="dd-export" style="flex:0 0 auto;">
        <button class="btn-green" id="btn-export">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
          Exportar
        </button>
        <div class="cb-dropdown-panel" id="dd-export-panel">
          <div class="cb-panel-item" id="exp-excel">Excel (.xlsx)</div>
          <div class="cb-panel-item" id="exp-csv">CSV (.csv)</div>
        </div>
      </div>
    </div>
  </div>

  <div class="status-bar">
    <div class="loading-bar active" id="loading-bar">
      <div class="spinner"></div>
      <span id="loading-msg">Cargando productos...</span>
    </div>
  </div>

  <main>
    <div class="card">
      <div class="tbl-wrap">
        <div id="tbl-head"></div>
        <div id="table-body"></div>
      </div>
      <div class="pagination" id="pagination"></div>
    </div>
  </main>

<div class="lightbox" id="lightbox">
  <span class="lightbox-close" id="lightbox-close">&times;</span>
  <img id="lightbox-img" src="" alt="" />
</div>
<div class="toast-container" id="toast-container"></div>

