/* ================================================================
   getVisibleColumns — respects currentView + priceToggle + role
================================================================ */
function getVisibleColumns() {
  var base;
  if (currentView === 'summary') {
    base = ALL_COLUMNS.filter(function(c) {
      return !c.price && SUMMARY_FIELDS.indexOf(c.field) !== -1;
    });
  } else {
    base = ALL_COLUMNS.filter(function(c) { return !c.price; });
  }

  var priceFields = [];

  if (priceToggle.propio) {
    var own = PROPIO_BY_ROLE[currentRole] || [];
    own.forEach(function(f) { if (priceFields.indexOf(f) === -1) priceFields.push(f); });
  }
  if (priceToggle.canal) {
    var ch = CANAL_BY_ROLE[currentRole] || [];
    ch.forEach(function(f) { if (priceFields.indexOf(f) === -1) priceFields.push(f); });
  }
  if (priceToggle.ml) {
    ALL_COLUMNS.forEach(function(c) {
      if (c.price && c.group === 'ml' && priceFields.indexOf(c.field) === -1) priceFields.push(c.field);
    });
  }

  /* Append price columns in their original order */
  ALL_COLUMNS.forEach(function(c) {
    if (c.price && priceFields.indexOf(c.field) !== -1) base.push(c);
  });

  return base;
}

