  // ── DROPDOWNS ─────────────────────────────────────────────────────────
  function buildDropdown(id, label) {
    var btn   = document.getElementById('dd-'+id+'-btn');
    var panel = document.getElementById('dd-'+id+'-panel');
    var list  = document.getElementById('dd-'+id+'-list');
    var si    = document.getElementById('dd-'+id+'-search');
    var cl    = document.getElementById('dd-'+id+'-clear');
    var cnt   = document.getElementById('dd-'+id+'-count');

    function renderList(q) {
      q = (q||'').toLowerCase();
      list.innerHTML = dropdownValues[id]
        .filter(function(v){ return !q || String(v).toLowerCase().includes(q); })
        .map(function(v,i) {
          var id2 = 'cb-'+id+'-'+i;
          return '<div class="cb-panel-item"><input type="checkbox" id="'+id2+'" value="'+String(v).replace(/'/g,'&#39;')+'" '+(filterState[id][v]?'checked':'')+"><label for='"+id2+"'>"+v+'</label></div>';
        }).join('') || '<div style="padding:8px 12px;color:#aaa;font-size:.82rem;">Sin resultados</div>';
      list.querySelectorAll('input[type=checkbox]').forEach(function(cb){
        cb.addEventListener('change', function(){
          if(cb.checked) filterState[id][cb.value]=true; else delete filterState[id][cb.value];
          updateLabel(); doSearch(1);
        });
      });
    }
    function updateLabel() {
      var sel = Object.keys(filterState[id]);
      btn.textContent = sel.length===0 ? label : sel.length===1 ? sel[0] : sel.length + ' seleccionados';
      btn.classList.toggle('has-selection', sel.length > 0);
      cnt.textContent = sel.length ? sel.length + ' selec.' : '';
    }
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var o = panel.classList.contains('open');
      closeAll();
      if(!o){ panel.classList.add('open'); btn.classList.add('open'); renderList(''); si.value=''; si.focus(); }
    });
    si.addEventListener('input', function(){ renderList(si.value); });
    cl.addEventListener('click', function(){ filterState[id]={}; updateLabel(); renderList(si.value); doSearch(1); });
  }

  function closeAll() {
    ['marca','linea','serie','export'].forEach(function(k){
      var p = document.getElementById('dd-'+k+'-panel');
      var b = document.getElementById('dd-'+k+'-btn');
      if(p) p.classList.remove('open');
      if(b) b.classList.remove('open');
    });
  }
  document.addEventListener('click', closeAll);
  ['dd-marca','dd-linea','dd-serie','dd-export'].forEach(function(id){
    var el = document.getElementById(id);
    if(el) el.addEventListener('click', function(e){ e.stopPropagation(); });
  });

  // ── TABLE ─────────────────────────────────────────────────────────────
  var FIXED_LEFT  = [
    { label:'Modelo',    flex:3.5 }, { label:'Marca',    flex:1.2 },
    { label:'Linea',     flex:1.8 }, { label:'Serie',    flex:1.2 },
    { label:'Funciones', flex:4   }
  ];
  var FIXED_RIGHT = [{ label:'Foto', flex:0.8 }];

  function calcMinWidth(pCols) {
    var fixedFlex = FIXED_LEFT.reduce(function(a,c){ return a+c.flex; },0) + FIXED_RIGHT[0].flex;
    var pFlex     = pCols.reduce(function(a,c){ return a+c.flex; }, 0);
    return Math.ceil((fixedFlex + pFlex) * 100);
  }

  function buildHeader() {
    var head = document.getElementById('tbl-head');
    head.innerHTML = '';
    var pCols = getVisiblePriceCols();
    var minW  = calcMinWidth(pCols);
    head.style.cssText = 'display:flex;flex-direction:row;align-items:stretch;background:linear-gradient(90deg,#5a0000,#800000);position:sticky;top:0;z-index:10;min-width:'+minW+'px;width:100%;';
    FIXED_LEFT.concat(pCols).concat(FIXED_RIGHT).forEach(function(col){
      var d = document.createElement('div');
      d.style.cssText = 'flex:'+col.flex+';min-width:0;display:flex;align-items:center;justify-content:center;text-align:center;padding:8px 6px;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:white;box-sizing:border-box;border-right:1px solid rgba(255,255,255,.1);overflow:hidden;';
      d.textContent = col.label;
      head.appendChild(d);
    });
  }

  function makeCell(content, flex, align) {
    var d  = document.createElement('div');
    var jc = align === 'left' ? 'flex-start' : 'center';
    var pl = align === 'left' ? '14px' : '8px';
    d.style.cssText = 'flex:'+flex+';min-width:0;display:flex;align-items:center;justify-content:'+jc+';text-align:'+(align==='left'?'left':'center')+';padding:4px '+pl+';font-size:.78rem;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;';
    if(typeof content === 'string') d.innerHTML = content; else d.appendChild(content);
    return d;
  }

  function price(val, cls) {
    var n = parseFloat(val);
    if(!val || isNaN(n) || n <= 0) return "<span class='price p-zero'>–</span>";
    return "<span class='price "+cls+"'>$"+n.toLocaleString('es-AR',{minimumFractionDigits:0,maximumFractionDigits:2})+"</span>";
  }

  function render() {
    var body  = document.getElementById('table-body');
    body.innerHTML = '';
    if (!currentData.length) {
      var msg = document.createElement('div');
      msg.style.cssText = 'text-align:center;padding:48px;color:#aaa;';
      msg.textContent = 'No se encontraron productos.';
      body.appendChild(msg); return;
    }
    var pCols = getVisiblePriceCols();
    var minW  = calcMinWidth(pCols);
    var frag  = document.createDocumentFragment();

    currentData.forEach(function(p){
      var row = document.createElement('div');
      row.className = 'tbl-row';
      row.style.cssText = 'display:flex;flex-direction:row;align-items:stretch;width:100%;min-width:'+minW+'px;border-bottom:1px solid #e0e0e0;';

      var spanM = document.createElement('span'); spanM.className = 'modelo-txt'; spanM.textContent = p.modelo||'–';
      var cellM = document.createElement('div');
      cellM.style.cssText = 'flex:3.5;min-width:0;display:flex;align-items:center;justify-content:flex-start;padding:4px 14px;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;';
      cellM.appendChild(spanM);

      var func = (p.funciones||''); if(func.length>160) func=func.substring(0,160)+'...';
      var spanF = document.createElement('span'); spanF.className = 'func-txt'; spanF.textContent = func||'–';
      var cellF = document.createElement('div');
      cellF.style.cssText = 'flex:4;min-width:0;display:flex;align-items:center;justify-content:flex-start;padding:4px 10px;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;';
      cellF.appendChild(spanF);

      var foto = p.imagen||'';
      var fotoEl;
      if(foto) {
        var wrap = document.createElement('div');
        wrap.style.cssText = 'width:36px;height:36px;background:#fff;border:1px solid #eee;border-radius:4px;overflow:hidden;cursor:pointer;';
        wrap.dataset.foto = foto;
        wrap.addEventListener('click', function(){ openLB(this); });
        var img = document.createElement('img'); img.src = foto;
        img.style.cssText = 'width:36px;height:36px;object-fit:contain;';
        img.onerror = function(){ this.style.display='none'; };
        wrap.appendChild(img); fotoEl = wrap;
      } else {
        fotoEl = document.createElement('span'); fotoEl.style.color='#ddd'; fotoEl.textContent='–';
      }
      var cellFoto = document.createElement('div');
      cellFoto.style.cssText = 'flex:0.8;min-width:0;display:flex;align-items:center;justify-content:center;padding:3px;box-sizing:border-box;overflow:hidden;';
      cellFoto.appendChild(fotoEl);

      row.appendChild(cellM);
      row.appendChild(makeCell(p.marca||'–', 1.2, 'center'));
      row.appendChild(makeCell(p.linea||'–', 1.8, 'center'));
      row.appendChild(makeCell(p.serie||'–', 1.2, 'center'));
      row.appendChild(cellF);
      pCols.forEach(function(col){ row.appendChild(makeCell(price(p[col.field], col.cls), col.flex, 'center')); });
      row.appendChild(cellFoto);
      frag.appendChild(row);
    });
    body.appendChild(frag);
  }

  // ── PAGINATION ────────────────────────────────────────────────────────
  function paginate() {
    var pages = Math.ceil(totalCount / PAGE_SIZE);
    var pag   = document.getElementById('pagination');
    if(pages <= 1) { pag.innerHTML = "<span class='page-info'>"+totalCount+" productos</span>"; return; }
    var h = "<button class='page-btn' id='pp'"+(currentPage===1?' disabled':'')+">Anterior</button>";
    for(var i=1;i<=pages;i++) {
      if(i===1||i===pages||Math.abs(i-currentPage)<=2)
        h += "<button class='page-btn"+(i===currentPage?' active':'')+"' data-p='"+i+"'>"+i+"</button>";
      else if(Math.abs(i-currentPage)===3)
        h += "<span class='page-info'>…</span>";
    }
    h += "<button class='page-btn' id='pn'"+(currentPage===pages?' disabled':'')+">Siguiente</button>";
    h += "<span class='page-info'>Pág "+currentPage+"/"+pages+" · "+totalCount+" productos</span>";
    pag.innerHTML = h;
    document.getElementById('pp').onclick = function(){ doSearch(currentPage-1); };
    document.getElementById('pn').onclick = function(){ doSearch(currentPage+1); };
    pag.querySelectorAll('[data-p]').forEach(function(b){ b.onclick = function(){ doSearch(+b.dataset.p); }; });
    document.querySelector('.tbl-wrap').scrollTop = 0;
  }

  // ── EXPORT ────────────────────────────────────────────────────────────
  async function fetchAllFiltered() {
    var allRows=[]; var offset=0; var limit=1000;
    while(true) {
      var url = buildQuery(1, limit, offset);
      var res = await fetch(url, { headers: H, cache: 'no-store' });
      var chunk = await res.json();
      if(!Array.isArray(chunk)||chunk.length===0) break;
      allRows = allRows.concat(chunk);
      if(chunk.length < limit) break;
      offset += limit;
    }
    return allRows;
  }

  function toExportRow(p) {
    var row = { SAP: p.sap||'', Modelo: p.modelo||'', Marca: p.marca||'', Linea: p.linea||'', Serie: p.serie||'', Funciones: p.funciones||'' };
    getVisiblePriceCols().forEach(function(col){ row[col.label + ' USD'] = p[col.field]||''; });
    return row;
  }

  document.getElementById('btn-export').addEventListener('click', function(e){
    e.stopPropagation();
    var panel = document.getElementById('dd-export-panel');
    var o = panel.classList.contains('open'); closeAll(); if(!o) panel.classList.add('open');
  });
  document.getElementById('exp-excel').addEventListener('click', async function(){
    showToast('Preparando Excel...','update');
    var rows = await fetchAllFiltered();
    var ws = XLSX.utils.json_to_sheet(rows.map(toExportRow));
    var wb = XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb,ws,'Productos'); XLSX.writeFile(wb,'catalogo.xlsx');
    closeAll();
  });
  document.getElementById('exp-csv').addEventListener('click', async function(){
    showToast('Preparando CSV...','update');
    var rows = await fetchAllFiltered();
    var d = rows.map(toExportRow), k = Object.keys(d[0]||{});
    var csv = k.join(',') + '\n' + d.map(function(r){ return k.map(function(key){ var v=String(r[key]||''); return v.includes(',')||v.includes('"')?'"'+v.replace(/"/g,'""')+'"':v; }).join(','); }).join('\n');
    var a = document.createElement('a'); a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'})); a.download='catalogo.csv'; a.click();
    closeAll();
  });

  // ── LIGHTBOX ──────────────────────────────────────────────────────────
  function openLB(el) {
    document.getElementById('lightbox-img').src = el.dataset.foto;
    document.getElementById('lightbox').classList.add('active');
  }
  document.getElementById('lightbox').addEventListener('click', function(){
    document.getElementById('lightbox').classList.remove('active');
  });
  document.getElementById('lightbox-close').addEventListener('click', function(e){
    e.stopPropagation();
    document.getElementById('lightbox').classList.remove('active');
  });

  // ── REALTIME ──────────────────────────────────────────────────────────
  function initRealtime() {
    try {
      var ws = new WebSocket('wss://mywtmrwjzwpwkctixnzi.supabase.co/realtime/v1/websocket?apikey='+SB_KEY+'&vsn=1.0.0');
      ws.onopen = function() {
        ws.send(JSON.stringify({ topic:'realtime:public:productos', event:'phx_join', payload:{ config:{ broadcast:{ self:false } } }, ref:'1' }));
        setRtStatus('connected','En vivo');
      };
      ws.onmessage = function(e) {
        var msg; try { msg = JSON.parse(e.data); } catch(err){ return; }
        if(msg.event === 'heartbeat') { ws.send(JSON.stringify({ topic:'phoenix', event:'heartbeat', payload:{}, ref:'hb' })); return; }
        if(msg.event==='INSERT'||msg.event==='UPDATE'||msg.event==='DELETE') {
          doSearch(currentPage);
          showToast(msg.event==='INSERT'?'Producto agregado':msg.event==='UPDATE'?'Catálogo actualizado':'Producto eliminado','update');
        }
      };
      ws.onerror = function() { setRtStatus('disconnected','Sin conexión'); };
      ws.onclose = function() { setRtStatus('connecting','Reconectando...'); setTimeout(initRealtime, 5000); };
    } catch(e) {
      console.warn('[REALTIME] Error:', e.message);
      setRtStatus('disconnected','Sin conexión');
    }
  }

  // ── START ─────────────────────────────────────────────────────────────
  async function start() {
    try {
      var [result] = await Promise.all([fetchPage(1), fetchDropdownValues()]);
      currentData = result.data; totalCount = result.total;
      buildDropdown('marca','Todas las marcas');
      buildDropdown('linea','Todas las lineas');
      buildDropdown('serie','Todas las series');
      render(); paginate();
      document.getElementById('loading-bar').classList.remove('active');
      initRealtime();
    } catch(err) {
      console.error('ERROR al iniciar:', err);
      document.getElementById('loading-msg').textContent = 'Error: ' + err.message;
      setRtStatus('disconnected','Error');
    }
  }

  // ── INIT: crear cliente Supabase al cargar ────────────────────────────
  window.addEventListener('load', function() {
    initSupabase();
  });
</script>

</body>
</html>