    { label:'% PROMO ML CUOTA REDUCIDA',                    field:'promo_ml_cuotared',   flex:1.0,  always:true },
    { label:'MAP ML PROMO 1 Cuota ARS c/IVA',               field:'map_promo_1cuota',    flex:1.3,  price:true, cls:'p-map', roles:['diamond','black','platino','ruby','gold','guest'] },
    { label:'MAP ML PROMO 3 Cuotas ARS c/IVA',              field:'map_promo_3cuotas',   flex:1.3,  price:true, cls:'p-map', roles:['diamond','black','platino','ruby','gold','guest'] },
    { label:'MAP ML PROMO 6 Cuotas ARS c/IVA',              field:'map_promo_6cuotas',   flex:1.3,  price:true, cls:'p-map', roles:['diamond','black','platino','ruby','gold','guest'] },
    { label:'MAP ML PROMO 9 Cuotas ARS c/IVA',              field:'map_promo_9cuotas',   flex:1.3,  price:true, cls:'p-map', roles:['diamond','black','platino','ruby','gold','guest'] },
    { label:'MAP ML PROMO 12 Cuotas ARS c/IVA',             field:'map_promo_12cuotas',  flex:1.3,  price:true, cls:'p-map', roles:['diamond','black','platino','ruby','gold','guest'] },
    { label:'MAP ML PROMO Cuota Reducida ARS c/IVA',        field:'map_promo_cuotared',  flex:1.4,  price:true, cls:'p-map', roles:['diamond','black','platino','ruby','gold','guest'] }
  ];

  function getVisibleColumns() {
    return ALL_COLUMNS.filter(function(c) {
      if (c.always || c.image) return true;
      if (c.price && c.roles) return c.roles.includes(currentRole);
      return false;
    });
  }

  /* ═══════════════════════════════════════════════════
     SUPABASE INIT
  ═══════════════════════════════════════════════════ */
  function initSupabase() {
    try {
      if (typeof supabase === 'undefined' || !supabase.createClient) return false;
      sbClient = supabase.createClient(SB_URL, SB_KEY);
      return true;
    } catch(e) { return false; }
  }

  /* ═══════════════════════════════════════════════════
     LOGIN
  ═══════════════════════════════════════════════════ */
  function showLoginAlert(msg, type) {
    var el = document.getElementById('login-alert');
    el.textContent = msg;
    el.className = 'login-alert ' + (type || 'err');
    el.style.display = 'block';
  }

  async function fetchRole(email, userToken) {
    try {
      var authH = { apikey: SB_KEY, Authorization: 'Bearer ' + userToken, 'Content-Type': 'application/json' };
      var res = await fetch(SB_URL + '/rest/v1/usuarios?email=eq.' + encodeURIComponent(email) + '&select=rol&limit=1', { headers: authH });
      if (res.ok) {
        var rows = await res.json();
        if (rows.length && rows[0].rol) return String(rows[0].rol).toLowerCase();
      }
    } catch(e) {}
    return 'guest';
  }

  document.getElementById('btn-login').addEventListener('click', async function() {
    var email = document.getElementById('login-email').value.trim().toLowerCase();
    var pass  = document.getElementById('login-pass').value;
    if (!email || !pass) { showLoginAlert('Completá email y contraseña.'); return; }
    var btn = this; btn.textContent = 'Ingresando...'; btn.disabled = true;
    if (!sbClient && !initSupabase()) { showLoginAlert('Error de conexión.'); btn.disabled = false; return; }
    try {
      var authResult = await sbClient.auth.signInWithPassword({ email: email, password: pass });
      if (authResult.error) { showLoginAlert('Credenciales incorrectas.'); btn.disabled = false; btn.textContent = 'Ingresar'; return; }
      currentRole = await fetchRole(email, authResult.data.session.access_token);
      launchApp(email);
    } catch(e) { showLoginAlert('Error de conexión'); btn.disabled = false; btn.textContent = 'Ingresar'; }
  });

  document.getElementById('btn-guest').addEventListener('click', function() { currentRole = 'guest'; launchApp(null); });
  document.getElementById('btn-logout').addEventListener('click', async function() { try { if(sbClient) await sbClient.auth.signOut(); } catch(e){} location.reload(); });

  function launchApp(email) {
    document.getElementById('login-overlay').style.display = 'none';
    var app = document.getElementById('app');
    app.style.display = 'flex';
    if (email) {
      document.getElementById('usr-badge').textContent = email;
      var pill = document.getElementById('role-pill');
      var roleLabel = { diamond:'Diamond', black:'Black', platino:'Platinum', ruby:'Ruby', gold:'Gold', guest:'MAP' }[currentRole] || currentRole;
      pill.textContent = roleLabel;
      pill.className = 'role-pill role-' + currentRole;
      pill.style.display = 'inline-block';
      document.getElementById('btn-logout').style.display = 'block';
    }
    buildHeader();
    start();
  }

  /* ═══════════════════════════════════════════════════
     TOASTS
  ═══════════════════════════════════════════════════ */
  function showToast(msg, type) {
    var c = document.getElementById('toast-container');
    var t = document.createElement('div');
    t.className = 'toast' + (type ? ' ' + type : '');
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(function() { t.classList.add('show'); }, 10);
    setTimeout(function() { t.remove(); }, 3500);
  }

  /* ═══════════════════════════════════════════════════
     SCORE
  ═══════════════════════════════════════════════════ */
  var SCORE_FIELDS = [
    'sku_base','sku_codigo','sap','marca','modelo','funciones',
    'sales_status','reemplazo_sug','market_segment','cate_target',
    'cat_madre','cat_line','line_offer','line_focus','selection',
    'sistema_precios','diamond_usd','platinum_usd','ruby_usd',
    'gold_gremio_usd','gold_plus_usd','gold_prime_usd',
    'iva','iitt','map_web_ars','map_ars',
    'cuotas_sin_recargo','promo_ml_1cuota','promo_ml_3cuotas',
    'promo_ml_6cuotas','promo_ml_9cuotas','promo_ml_12cuotas','promo_ml_cuotared',
    'map_promo_1cuota','map_promo_3cuotas','map_promo_6cuotas',
    'map_promo_9cuotas','map_promo_12cuotas','map_promo_cuotared',
    'imagen','linea','serie'
  ];

  function completenessScore(p) {
    var score = 0;
    SCORE_FIELDS.forEach(function(f) {
      var v = p[f];
      if (v !== null && v !== undefined && String(v).trim() !== '') score++;
    });
    return score;
  }

  /* ═══════════════════════════════════════════════════
     DATASET GLOBAL — carga TODOS los productos paginando
     de a 1000 hasta agotar los registros
  ═══════════════════════════════════════════════════ */
  var allData = [];

  async function fetchAllProducts() {
    var msgEl = document.getElementById('loading-msg');
    var all = [];
    var batchSize = 1000;
    var offset = 0;
    var page = 1;

    while (true) {
      if (msgEl) msgEl.textContent = 'Cargando catálogo... ' + all.length + ' productos';

      var url = SB_URL + '/rest/v1/productos'
              + '?select=*'
              + '&list_mark=eq.true'
              + '&limit=' + batchSize
              + '&offset=' + offset
              + '&order=sap.asc';

      var res = await fetch(url, {
        headers: H,
        cache: 'no-store'
      });

      if (!res.ok) {
        var errBody = '';
        try { errBody = await res.text(); } catch(e2) {}
        console.error('Supabase error', res.status, errBody);
        throw new Error('Error API ' + res.status + (errBody ? ': ' + errBody.substring(0, 200) : ''));
      }

      var rows = await res.json();
      if (!Array.isArray(rows) || rows.length === 0) break;

      all = all.concat(rows);
      if (msgEl) msgEl.textContent = 'Cargando catálogo... ' + all.length + ' productos';

      // Si trajo menos que el batch, es la última página
      if (rows.length < batchSize) break;

      offset += batchSize;
      page++;
    }

    // Ordenar por completitud: los más completos primero
    all.forEach(function(p) { p._score = completenessScore(p); });
    all.sort(function(a, b) { return b._score - a._score; });

    return all;
  }

  /* ═══════════════════════════════════════════════════
     FILTRO + BÚSQUEDA CLIENT-SIDE
  ═══════════════════════════════════════════════════ */
  function applyFilters() {
    var q  = document.getElementById('search').value.trim().toLowerCase();
    var ma = Object.keys(filterState.marca);
    var li = Object.keys(filterState.linea);
    var se = Object.keys(filterState.serie);

    return allData.filter(function(p) {
      if (ma.length && !ma.includes(p.marca)) return false;
      if (li.length && !li.includes(p.linea)) return false;
      if (se.length && !se.includes(p.serie)) return false;
      if (q) {
        var hay = [p.modelo, p.funciones, p.sku_codigo, p.sap, p.sku_base]
          .map(function(v) { return v ? String(v).toLowerCase() : ''; })
          .join(' ');
        if (!hay.includes(q)) return false;
      }
      return true;
    });
  }

  function doSearch(page) {
    currentPage = page || 1;
    document.getElementById('search-spinner').classList.add('active');
    var filtered = applyFilters();
    totalCount = filtered.length;
    var off = (currentPage - 1) * PAGE_SIZE;
    currentData = filtered.slice(off, off + PAGE_SIZE);
    render(); paginate();
    document.getElementById('search-spinner').classList.remove('active');
  }

  document.getElementById('search').addEventListener('input', function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function(){ doSearch(1); }, 200);
  });

  /* ═══════════════════════════════════════════════════
     DROPDOWNS
  ═══════════════════════════════════════════════════ */
  function buildDropdownValues() {
    dropdownValues.marca = [...new Set(allData.map(r => r.marca).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
    dropdownValues.linea = [...new Set(allData.map(r => r.linea).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
    dropdownValues.serie = [...new Set(allData.map(r => r.serie).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
  }

  function buildDropdown(id, label) {
    var btn  = document.getElementById('dd-' + id + '-btn');
    var panel= document.getElementById('dd-' + id + '-panel');
    var list = document.getElementById('dd-' + id + '-list');
    var si   = document.getElementById('dd-' + id + '-search');
    var cl   = document.getElementById('dd-' + id + '-clear');
    var cnt  = document.getElementById('dd-' + id + '-count');

    function renderList(q) {
      q = (q || '').toLowerCase();
      var filtered = dropdownValues[id].filter(v => !q || String(v).toLowerCase().includes(q));
      list.innerHTML = filtered.map((v, i) =>
        '<div class="cb-panel-item"><input type="checkbox" id="cb-' + id + '-' + i + '" value="' + String(v).replace(/'/g,'&#39;') + '" ' + (filterState[id][v] ? 'checked' : '') + '><label for="cb-' + id + '-' + i + '">' + v + '</label></div>'
      ).join('') || '<div style="padding:8px 12px;color:#aaa;">Sin resultados</div>';
      list.querySelectorAll('input[type=checkbox]').forEach(cb => cb.addEventListener('change', function() {
        if (cb.checked) filterState[id][cb.value] = true; else delete filterState[id][cb.value];
        updateLabel(); doSearch(1);
      }));
    }

    function updateLabel() {
      var sel = Object.keys(filterState[id]);
      btn.textContent = sel.length === 0 ? label : sel.length === 1 ? sel[0] : sel.length + ' seleccionados';
      cnt.textContent = sel.length ? sel.length + ' selec.' : '';
    }

    btn.addEventListener('click', function(e) {
      e.stopPropagation(); closeAll(); panel.classList.toggle('open');
      if (panel.classList.contains('open')) { renderList(''); si.value = ''; si.focus(); }
    });
    si.addEventListener('input', function() { renderList(si.value); });
    cl.addEventListener('click', function() { filterState[id] = {}; updateLabel(); renderList(si.value); doSearch(1); });
  }

  function closeAll() {
    ['marca','linea','serie','export'].forEach(k => {
      var p = document.getElementById('dd-' + k + '-panel');
      if (p) p.classList.remove('open');
    });
  }
  document.addEventListener('click', closeAll);
  ['dd-marca','dd-linea','dd-serie','dd-export'].forEach(id => {
    var el = document.getElementById(id);
    if (el) el.addEventListener('click', e => e.stopPropagation());
  });

  /* ═══════════════════════════════════════════════════
     RENDER TABLE
  ═══════════════════════════════════════════════════ */
  function buildHeader() {
    var head = document.getElementById('tbl-head');
    head.innerHTML = '';
    var cols = getVisibleColumns();
    var minW = cols.reduce((a, c) => a + c.flex, 0) * 88;
    head.style.cssText = 'display:flex;background:linear-gradient(90deg,#5a0000,#800000);position:sticky;top:0;z-index:10;min-width:' + minW + 'px;width:100%;';
    cols.forEach(function(col) {
      var d = document.createElement('div');
      d.style.cssText = 'flex:' + col.flex + ';min-width:0;display:flex;align-items:center;justify-content:center;text-align:center;padding:7px 4px;font-size:.64rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:white;border-right:1px solid rgba(255,255,255,.1);overflow:hidden;word-break:break-word;line-height:1.25;';
      d.textContent = col.label;
      head.appendChild(d);
    });
  }

  function formatPrice(val, cls) {
    var n = parseFloat(String(val).replace(/[^0-9.,]/g, '').replace(',', '.'));
    if (isNaN(n) || n <= 0) return "<span class='price p-zero'>–</span>";
    return "<span class='price " + cls + "'>$" + n.toLocaleString('es-AR', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) + "</span>";
  }

  function makeImageCell(val, flex) {
    var d = document.createElement('div');
    d.style.cssText = 'flex:' + flex + ';min-width:0;display:flex;align-items:center;justify-content:center;padding:5px 4px;border-right:1px solid #f0f0f0;';
    if (!val) { d.innerHTML = '<span style="color:#ccc;font-size:.7rem;">–</span>'; return d; }
    var wrap = document.createElement('div');
    wrap.style.cssText = 'width:38px;height:38px;background:#fff;border:1px solid #eee;border-radius:5px;overflow:hidden;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;';
    wrap.dataset.foto = val;
    wrap.addEventListener('click', function() {
      document.getElementById('lightbox-img').src = this.dataset.foto;
      document.getElementById('lightbox').classList.add('active');
    });
    var img = document.createElement('img');
    img.src = val; img.style.cssText = 'width:38px;height:38px;object-fit:contain;';
    img.onerror = function() { this.style.display = 'none'; wrap.innerHTML = '<span style="font-size:.6rem;color:#ccc;">Sin foto</span>'; };
    wrap.appendChild(img); d.appendChild(wrap);
    return d;
  }

  function makeCell(content, flex, alignLeft) {
    var d = document.createElement('div');
    var jc = alignLeft ? 'flex-start' : 'center';
    var ta = alignLeft ? 'left' : 'center';
    d.style.cssText = 'flex:' + flex + ';min-width:0;display:flex;align-items:center;justify-content:' + jc + ';text-align:' + ta + ';padding:5px 4px;font-size:.72rem;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;word-break:break-word;line-height:1.3;';
    if (typeof content === 'string') d.innerHTML = content; else d.appendChild(content);
    return d;
  }

  function render() {
    var body = document.getElementById('table-body');
    body.innerHTML = '';
    if (!currentData.length) {
      body.innerHTML = '<div style="text-align:center;padding:48px;color:#aaa;">No se encontraron productos.</div>';
      return;
    }
    var cols = getVisibleColumns();
    var minW = cols.reduce((a, c) => a + c.flex, 0) * 88;
    var frag = document.createDocumentFragment();

    currentData.forEach(function(p) {
      var row = document.createElement('div');
      row.className = 'tbl-row';
      row.style.cssText = 'display:flex;width:100%;min-width:' + minW + 'px;border-bottom:1px solid #e8e8e8;';

      cols.forEach(function(col) {
        // Intentar imagen desde 'imagen' o 'foto_url'
        var val = p[col.field];
        if (col.field === 'imagen' && !val) val = p['foto_url'];

        if (col.image) { row.appendChild(makeImageCell(val, col.flex)); return; }

        if (col.price) {
          var html = (val === undefined || val === null || val === '') ? "<span class='price p-zero'>–</span>" : formatPrice(val, col.cls);
          row.appendChild(makeCell(html, col.flex, false));
          return;
        }

        var txt = (val === undefined || val === null) ? '–' : String(val);
        if (txt === '') txt = '–';
        if (txt.length > 140) txt = txt.substring(0, 140) + '…';
        row.appendChild(makeCell(txt, col.flex, !!col.alignLeft));
      });

      frag.appendChild(row);
    });
    body.appendChild(frag);
  }

  /* ═══════════════════════════════════════════════════
     PAGINACIÓN
  ═══════════════════════════════════════════════════ */
  function paginate() {
    var pages = Math.ceil(totalCount / PAGE_SIZE);
    var pag = document.getElementById('pagination');
    if (pages <= 1) { pag.innerHTML = "<span class='page-info'>" + totalCount + " productos</span>"; return; }
    var h = "<button class='page-btn' id='pp'" + (currentPage === 1 ? ' disabled' : '') + ">◀ Anterior</button>";
    for (var i = 1; i <= pages; i++) {
      if (i === 1 || i === pages || Math.abs(i - currentPage) <= 2)
        h += "<button class='page-btn" + (i === currentPage ? ' active' : '') + "' data-p='" + i + "'>" + i + "</button>";
      else if (Math.abs(i - currentPage) === 3)
        h += "<span class='page-info'>…</span>";
    }
    h += "<button class='page-btn' id='pn'" + (currentPage === pages ? ' disabled' : '') + ">Siguiente ▶</button>";
    h += "<span class='page-info'>Pág " + currentPage + "/" + pages + " · " + totalCount + " productos</span>";
    pag.innerHTML = h;
    document.getElementById('pp')?.addEventListener('click', () => doSearch(currentPage - 1));
    document.getElementById('pn')?.addEventListener('click', () => doSearch(currentPage + 1));
    pag.querySelectorAll('[data-p]').forEach(b => b.addEventListener('click', () => doSearch(+b.dataset.p)));
  }

  /* ═══════════════════════════════════════════════════
     EXPORT
  ═══════════════════════════════════════════════════ */
  document.getElementById('btn-export').addEventListener('click', function(e) {
    e.stopPropagation();
    var p = document.getElementById('dd-export-panel');
    closeAll(); p.classList.toggle('open');
  });

  document.getElementById('exp-excel').addEventListener('click', async function() {
    showToast('Preparando Excel...', 'update');
    var rows = applyFilters();
    var cols = getVisibleColumns().filter(c => !c.image);
    var data = rows.map(function(p) {
      var obj = {};
      cols.forEach(function(c) { obj[c.label] = p[c.field] !== undefined ? p[c.field] : ''; });
      return obj;
    });
    var ws = XLSX.utils.json_to_sheet(data);
    var wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Productos');
    XLSX.writeFile(wb, 'catalogo_hikvision.xlsx');
    closeAll();
  });

  document.getElementById('exp-csv').addEventListener('click', async function() {
    showToast('Preparando CSV...', 'update');
    var rows = applyFilters();
    var cols = getVisibleColumns().filter(c => !c.image);
    var data = rows.map(function(p) {
      var obj = {};
      cols.forEach(function(c) { obj[c.label] = p[c.field] !== undefined ? p[c.field] : ''; });
      return obj;
    });
    if (data.length) {
      var keys = cols.map(c => c.label);
      var csv = keys.join(',') + '\n' + data.map(function(r) {
        return keys.map(function(k) {
          var v = String(r[k] || '');
          return (v.includes(',') || v.includes('"')) ? '"' + v.replace(/"/g, '""') + '"' : v;
        }).join(',');
      }).join('\n');
      var a = document.createElement('a');
      a.href = URL.createObjectURL(new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8' }));
      a.download = 'catalogo_hikvision.csv';
      a.click();
    }
    closeAll();
  });

  /* ═══════════════════════════════════════════════════
     LIGHTBOX
  ═══════════════════════════════════════════════════ */
  document.getElementById('lightbox').addEventListener('click', function() { this.classList.remove('active'); });
  document.getElementById('lightbox-close').addEventListener('click', function(e) { e.stopPropagation(); document.getElementById('lightbox').classList.remove('active'); });

  /* ═══════════════════════════════════════════════════
     START
  ═══════════════════════════════════════════════════ */
  async function start() {
    try {
      allData = await fetchAllProducts();

      buildDropdownValues();
      buildDropdown('marca', 'Todas las marcas');
      buildDropdown('linea', 'Todas las líneas');
      buildDropdown('serie', 'Todas las series');

      doSearch(1);

      document.getElementById('loading-msg').textContent = '✓ ' + allData.length + ' productos cargados';
      setTimeout(function() {
        document.getElementById('loading-bar').classList.remove('active');
      }, 2000);

      document.getElementById('rt-badge').className = 'rt-badge connected';
      document.getElementById('rt-label').textContent = 'Conectado';
    } catch(err) {
      console.error(err);
      document.getElementById('loading-msg').textContent = 'Error: ' + err.message;
      document.getElementById('rt-badge').className = 'rt-badge disconnected';
      document.getElementById('rt-label').textContent = 'Sin conexión';
    }
  }

  window.addEventListener('load', function() { initSupabase(); });
</script>
</body>
</html>