  function initSupabase() {
    try {
      if (typeof supabase === 'undefined' || !supabase.createClient) return false;
      sbClient = supabase.createClient(SB_URL, SB_KEY);
      return true;
    } catch(e) { return false; }
  }

  function showLoginAlert(msg, type) {
    var el = document.getElementById('login-alert');
    el.textContent = msg;
    el.className = 'login-alert ' + (type || 'err');
    el.style.display = 'block';
  }
  function setLoginStep(msg) { document.getElementById('login-step').textContent = msg; }
  
  async function fetchRole(email, userToken) {
    try {
      var authH = { apikey: SB_KEY, Authorization: 'Bearer ' + userToken, 'Content-Type': 'application/json' };
      var res = await fetch(SB_URL + '/rest/v1/usuarios?email=eq.' + encodeURIComponent(email) + '&select=rol&limit=1', { headers: authH });
      if (res.ok) { var rows = await res.json(); if (rows.length && rows[0].rol) return String(rows[0].rol).toLowerCase(); }
    } catch(e) {}
    return 'guest';
  }

  document.getElementById('btn-login').addEventListener('click', async function() {
    var email = document.getElementById('login-email').value.trim().toLowerCase();
    var pass = document.getElementById('login-pass').value;
    if (!email || !pass) { showLoginAlert('Completá email y contraseña.'); return; }
    var btn = this; btn.textContent = 'Ingresando...'; btn.disabled = true;
    if (!sbClient && !initSupabase()) { showLoginAlert('Error de conexión.'); btn.disabled=false; return; }
    try {
      var authResult = await sbClient.auth.signInWithPassword({ email: email, password: pass });
      if (authResult.error) { showLoginAlert('Credenciales incorrectas.'); btn.disabled=false; return; }
      var session = authResult.data.session;
      currentRole = await fetchRole(email, session.access_token);
      launchApp(email);
    } catch(e) { showLoginAlert('Error de conexión'); btn.disabled=false; }
  });

  document.getElementById('btn-guest').addEventListener('click', function() { currentRole = 'guest'; launchApp(null); });
  document.getElementById('btn-logout').addEventListener('click', async function() { try { if(sbClient) await sbClient.auth.signOut(); } catch(e){} location.reload(); });

  function launchApp(email) {
    document.getElementById('login-overlay').style.display = 'none';
    var app = document.getElementById('app');
    app.style.display = 'flex';
    if (email) {
      document.getElementById('usr-badge').textContent = email;
      var pill = document.getElementById('role-pill');
      var roleLabel = { diamond:'Diamond', black:'Black', platino:'Platinum', ruby:'Ruby', gold:'Gold', guest:'MAP' }[currentRole] || currentRole;
      pill.textContent = roleLabel;
      pill.className = 'role-pill role-' + currentRole;
      pill.style.display = 'inline-block';
      document.getElementById('btn-logout').style.display = 'block';
    }
    buildHeader();
    start();
  }

  function showToast(msg, type) {
    var c = document.getElementById('toast-container');
    var t = document.createElement('div');
    t.className = 'toast' + (type ? ' ' + type : '');
    t.textContent = msg; c.appendChild(t);
    setTimeout(function() { t.classList.add('show'); }, 10);
    setTimeout(function() { t.remove(); }, 3500);
  }

  function buildQuery(page, limitOverride, offsetOverride) {
    var q = document.getElementById('search').value.trim();
    var ma = Object.keys(filterState.marca);
    var li = Object.keys(filterState.linea);
    var se = Object.keys(filterState.serie);
    var lim = limitOverride || PAGE_SIZE;
    var off = (offsetOverride !== undefined) ? offsetOverride : (page - 1) * PAGE_SIZE;
    var url = SB_URL + '/rest/v1/productos?select=*&list_mark=eq.true';
    if (ma.length === 1) url += '&marca=eq.' + encodeURIComponent(ma[0]);
    else if (ma.length > 1) url += '&marca=in.(' + ma.map(encodeURIComponent).join(',') + ')';
    if (li.length === 1) url += '&linea=eq.' + encodeURIComponent(li[0]);
    else if (li.length > 1) url += '&linea=in.(' + li.map(encodeURIComponent).join(',') + ')';
    if (se.length === 1) url += '&serie=eq.' + encodeURIComponent(se[0]);
    else if (se.length > 1) url += '&serie=in.(' + se.map(encodeURIComponent).join(',') + ')';
    if (q) { var pattern = encodeURIComponent('"' + q + '"'); url += '&or=(modelo.ilike.' + pattern + ',funciones.ilike.' + pattern + ',sku_codigo.ilike.' + pattern + ',sap.ilike.' + pattern + ')'; }
    url += '&order=actualizado_en.desc&limit=' + lim + '&offset=' + off;
    return url;
  }

  async function fetchPage(page) {
    var url = buildQuery(page);
    var res = await fetch(url, { headers: { ...H, 'Prefer': 'count=exact' }, cache: 'no-store' });
    if (!res.ok) throw new Error("Error API: " + res.status);
    var data = await res.json();
    var cr = res.headers.get('content-range');
    var total = cr ? parseInt(cr.split('/')[1]) : (Array.isArray(data) ? data.length : 0);
    return { data: Array.isArray(data) ? data : [], total: total };
  }

  async function fetchDropdownValues() {
    try {
      var res = await fetch(SB_URL + '/rest/v1/productos?select=marca,linea,serie&list_mark=eq.true', { headers: H });
      var rows = await res.json();
      if (!Array.isArray(rows)) return;
      dropdownValues.marca = [...new Set(rows.map(r => r.marca).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
      dropdownValues.linea = [...new Set(rows.map(r => r.linea).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
      dropdownValues.serie = [...new Set(rows.map(r => r.serie).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
    } catch(e) {}
  }

  async function doSearch(page) {
    currentPage = page || 1;
    document.getElementById('search-spinner').classList.add('active');
    document.getElementById('loading-bar').classList.add('active');
    try {
      var result = await fetchPage(currentPage);
      currentData = result.data; totalCount = result.total;
      render(); paginate();
    } catch(err) { showToast('Error: ' + err.message, 'error'); }
    finally {
      document.getElementById('search-spinner').classList.remove('active');
      document.getElementById('loading-bar').classList.remove('active');
    }
  }

  document.getElementById('search').addEventListener('input', function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function(){ doSearch(1); }, 300);
  });

  function buildDropdown(id, label) {
    var btn = document.getElementById('dd-'+id+'-btn');
    var panel = document.getElementById('dd-'+id+'-panel');
    var list = document.getElementById('dd-'+id+'-list');
    var si = document.getElementById('dd-'+id+'-search');
    var cl = document.getElementById('dd-'+id+'-clear');
    var cnt = document.getElementById('dd-'+id+'-count');
    function renderList(q) {
      q = (q||'').toLowerCase();
      list.innerHTML = dropdownValues[id].filter(v => !q || String(v).toLowerCase().includes(q)).map((v,i) => '<div class="cb-panel-item"><input type="checkbox" id="cb-'+id+'-'+i+'" value="'+String(v).replace(/'/g,'&#39;')+'" '+(filterState[id][v]?'checked':'')+'><label for="cb-'+id+'-'+i+'">'+v+'</label></div>').join('') || '<div style="padding:8px 12px;color:#aaa;">Sin resultados</div>';
      list.querySelectorAll('input[type=checkbox]').forEach(cb => cb.addEventListener('change', function(){ if(cb.checked) filterState[id][cb.value]=true; else delete filterState[id][cb.value]; updateLabel(); doSearch(1); }));
    }
    function updateLabel() {
      var sel = Object.keys(filterState[id]);
      btn.textContent = sel.length===0 ? label : sel.length===1 ? sel[0] : sel.length + ' seleccionados';
      cnt.textContent = sel.length ? sel.length + ' selec.' : '';
    }
    btn.addEventListener('click', function(e){ e.stopPropagation(); closeAll(); panel.classList.toggle('open'); if(panel.classList.contains('open')){ renderList(''); si.value=''; si.focus(); } });
    si.addEventListener('input', function(){ renderList(si.value); });
    cl.addEventListener('click', function(){ filterState[id]={}; updateLabel(); renderList(si.value); doSearch(1); });
  }

  function closeAll() { ['marca','linea','serie','export'].forEach(k => { let p = document.getElementById('dd-'+k+'-panel'); if(p) p.classList.remove('open'); }); }
  document.addEventListener('click', closeAll);
  ['dd-marca','dd-linea','dd-serie','dd-export'].forEach(id => { let el = document.getElementById(id); if(el) el.addEventListener('click', e => e.stopPropagation()); });

  function buildHeader() {
    var head = document.getElementById('tbl-head');
    head.innerHTML = '';
    var cols = getVisibleColumns();
    var minW = cols.reduce((a,c)=> a + c.flex, 0) * 90;
    head.style.cssText = 'display:flex;background:linear-gradient(90deg,#5a0000,#800000);position:sticky;top:0;z-index:10;min-width:'+minW+'px;width:100%;';
    cols.forEach(col => {
      var d = document.createElement('div');
      d.style.cssText = 'flex:'+col.flex+';min-width:0;display:flex;align-items:center;justify-content:center;text-align:center;padding:8px 4px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:white;border-right:1px solid rgba(255,255,255,.1);overflow:hidden;word-break:break-word;';
      d.textContent = col.label;
      head.appendChild(d);
    });
  }

  function formatValue(val, col) {
    if (val === undefined || val === null || val === '') return '–';
    if (col.price) {
      var n = parseFloat(String(val).replace(/[^0-9.,]/g,'').replace(',','.'));
      if (isNaN(n) || n <= 0) return "<span class='price p-zero'>–</span>";
      return "<span class='price "+col.cls+"'>$"+n.toLocaleString('es-AR',{minimumFractionDigits:0,maximumFractionDigits:2})+"</span>";
    }
    if (col.image) {
      if (!val) return '–';
      var wrap = document.createElement('div');
      wrap.style.cssText = 'width:36px;height:36px;background:#fff;border:1px solid #eee;border-radius:4px;overflow:hidden;cursor:pointer;display:flex;align-items:center;justify-content:center;';
      wrap.dataset.foto = val;
      wrap.addEventListener('click', function(){ document.getElementById('lightbox-img').src = this.dataset.foto; document.getElementById('lightbox').classList.add('active'); });
      var img = document.createElement('img'); img.src = val; img.style.cssText = 'width:36px;height:36px;object-fit:contain;';
      img.onerror = function(){ this.style.display='none'; };
      wrap.appendChild(img);
      return wrap;
    }
    var txt = String(val);
    if (txt.length > 120) txt = txt.substring(0,120)+'...';
    return txt;
  }

  function makeCell(content, flex, align) {
    var d = document.createElement('div');
    var jc = align === 'left' ? 'flex-start' : 'center';
    d.style.cssText = 'flex:'+flex+';min-width:0;display:flex;align-items:center;justify-content:'+jc+';text-align:'+(align==='left'?'left':'center')+';padding:6px 4px;font-size:.74rem;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;word-break:break-word;';
    if (typeof content === 'string') d.innerHTML = content;
    else d.appendChild(content);
    return d;
  }

  function render() {
    var body = document.getElementById('table-body');
    body.innerHTML = '';
    if (!currentData.length) { body.innerHTML = '<div style="text-align:center;padding:48px;color:#aaa;">No se encontraron productos.</div>'; return; }
    var cols = getVisibleColumns();
    var minW = cols.reduce((a,c)=> a + c.flex, 0) * 90;
    var frag = document.createDocumentFragment();
    currentData.forEach(p => {
      var row = document.createElement('div');
      row.className = 'tbl-row';
      row.style.cssText = 'display:flex;width:100%;min-width:'+minW+'px;border-bottom:1px solid #e0e0e0;';
      cols.forEach(col => {
        var val = p[col.field];
        var formatted = formatValue(val, col);
        var align = (col.label === 'Modelo' || col.label === 'Funciones') ? 'left' : 'center';
        row.appendChild(makeCell(formatted, col.flex, align));
      });
      frag.appendChild(row);
    });
    body.appendChild(frag);
  }

  function paginate() {
    var pages = Math.ceil(totalCount / PAGE_SIZE);
    var pag = document.getElementById('pagination');
    if(pages <= 1) { pag.innerHTML = "<span class='page-info'>"+totalCount+" productos</span>"; return; }
    var h = "<button class='page-btn' id='pp'"+(currentPage===1?' disabled':'')+">Anterior</button>";
    for(var i=1;i<=pages;i++) {
      if(i===1||i===pages||Math.abs(i-currentPage)<=2) h += "<button class='page-btn"+(i===currentPage?' active':'')+"' data-p='"+i+"'>"+i+"</button>";
      else if(Math.abs(i-currentPage)===3) h += "<span class='page-info'>…</span>";
    }
    h += "<button class='page-btn' id='pn'"+(currentPage===pages?' disabled':'')+">Siguiente</button>";
    h += "<span class='page-info'>Pág "+currentPage+"/"+pages+" · "+totalCount+" productos</span>";
    pag.innerHTML = h;
    document.getElementById('pp')?.addEventListener('click', () => doSearch(currentPage-1));
    document.getElementById('pn')?.addEventListener('click', () => doSearch(currentPage+1));
    pag.querySelectorAll('[data-p]').forEach(b => b.addEventListener('click', () => doSearch(+b.dataset.p)));
  }

  async function fetchAllFiltered() {
    var allRows=[]; var offset=0; var limit=1000;
    while(true) {
      var url = buildQuery(1, limit, offset);
      var res = await fetch(url, { headers: H });
      var chunk = await res.json();
      if(!Array.isArray(chunk)||chunk.length===0) break;
      allRows = allRows.concat(chunk);
      if(chunk.length < limit) break;
      offset += limit;
    }
    return allRows;
  }

  document.getElementById('btn-export').addEventListener('click', e => { e.stopPropagation(); var p = document.getElementById('dd-export-panel'); closeAll(); p.classList.toggle('open'); });
  document.getElementById('exp-excel').addEventListener('click', async () => {
    showToast('Preparando Excel...','update');
    var rows = await fetchAllFiltered();
    var cols = getVisibleColumns().filter(c => !c.image);
    var data = rows.map(p => { var obj = {}; cols.forEach(c => { obj[c.label] = p[c.field] || ''; }); return obj; });
    var ws = XLSX.utils.json_to_sheet(data);
    var wb = XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb,ws,'Productos'); XLSX.writeFile(wb,'catalogo.xlsx');
    closeAll();
  });
  document.getElementById('exp-csv').addEventListener('click', async () => {
    showToast('Preparando CSV...','update');
    var rows = await fetchAllFiltered();
    var cols = getVisibleColumns().filter(c => !c.image);
    var data = rows.map(p => { var obj = {}; cols.forEach(c => { obj[c.label] = p[c.field] || ''; }); return obj; });
    if(data.length){
      var keys = cols.map(c=>c.label);
      var csv = keys.join(',') + '\n' + data.map(r => keys.map(k => { var v=String(r[k]||''); return v.includes(',')||v.includes('"')?'"'+v.replace(/"/g,'""')+'"':v; }).join(',')).join('\n');
      var a = document.createElement('a'); a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'})); a.download='catalogo.csv'; a.click();
    }
    closeAll();
  });

  document.getElementById('lightbox').addEventListener('click', () => document.getElementById('lightbox').classList.remove('active'));
  document.getElementById('lightbox-close').addEventListener('click', e => { e.stopPropagation(); document.getElementById('lightbox').classList.remove('active'); });

  async function start() {
    try {
      var [result] = await Promise.all([fetchPage(1), fetchDropdownValues()]);
      currentData = result.data; totalCount = result.total;
      buildDropdown('marca','Todas las marcas');
      buildDropdown('linea','Todas las líneas');
      buildDropdown('serie','Todas las series');
      render(); paginate();
      document.getElementById('loading-bar').classList.remove('active');
      // Actualizar badge de conexión
      var rtBadge = document.getElementById('rt-badge');
      var rtLabel = document.getElementById('rt-label');
      rtBadge.className = 'rt-badge connected';
      rtLabel.textContent = 'Conectado';
    } catch(err) {
      console.error(err);
      document.getElementById('loading-msg').textContent = 'Error: ' + err.message;
      var rtBadge = document.getElementById('rt-badge');
      var rtLabel = document.getElementById('rt-label');
      rtBadge.className = 'rt-badge disconnected';
      rtLabel.textContent = 'Sin conexión';
    }
  }

  window.addEventListener('load', () => { initSupabase(); });
</script>
</body>
</html>
