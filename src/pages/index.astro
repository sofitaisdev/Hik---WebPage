<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Catálogo Maestro Hikvision</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script is:inline src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <style>
        :root { --bordo: #800000; --negro: #1a1a1a; --gris: #f4f7f6; }
        body { background-color: var(--gris); font-family: system-ui, sans-serif; margin: 0; padding: 10px; }
        .container { width: 100%; max-width: 100%; margin: 0 auto; }
        .filter-bar { 
            background: #fff; padding: 15px; border-radius: 8px; 
            display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.5fr 120px; gap: 10px; 
            margin-bottom: 15px; border-top: 4px solid var(--bordo); box-shadow: 0 2px 8px rgba(0,0,0,0.1); 
        }
        .filter-group { display: flex; flex-direction: column; gap: 3px; }
        .filter-group label { font-weight: bold; font-size: 10px; text-transform: uppercase; color: #555; }
        .filter-group input, .filter-group select { border: 1px solid #ddd; padding: 8px; border-radius: 4px; font-size: 12px; outline: none; }
        #btn-excel { background: #1b5e20; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; height: 35px; margin-top: auto; }
        .paging { display: flex; justify-content: center; align-items: center; gap: 20px; background: #fff; padding: 8px; border-radius: 6px; margin-bottom: 10px; }
        .nav-btn { background: var(--negro); color: white; border: none; padding: 6px 15px; border-radius: 4px; cursor: pointer; font-size: 12px; }
        .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }
        #page-info { font-weight: bold; font-size: 12px; color: var(--bordo); }
        .wrapper { width: 100%; overflow-x: auto; background: white; border-radius: 6px; }
        table { border-collapse: collapse; width: 100%; min-width: 2800px; table-layout: fixed; }
        thead th { padding: 12px 5px; font-size: 9px; color: #fff; text-align: center; position: sticky; top: 0; z-index: 10; background: var(--negro); }
        .th-bordo { background-color: var(--bordo) !important; }
        tbody td { padding: 8px 4px; border-bottom: 1px solid #f0f0f0; text-align: center; font-size: 10px; vertical-align: middle; }
        .col-mod { text-align: left; font-weight: bold; color: var(--bordo); width: 220px; }
        .col-tech { text-align: left; font-size: 8.5px; color: #666; width: 250px; white-space: normal; line-height: 1.1; }
        .img-prod { height: 45px; width: 45px; object-fit: contain; background: #fff; }
        .p-vta { font-weight: bold; color: #2e7d32; }
        .no-price { color: #ccc; }
    </style>
</head>
<body>
    <div class="container">
        <div class="filter-bar">
            <div class="filter-group"><label>Buscador</label><input type="text" id="buscador" placeholder="Modelo o SAP..."></div>
            <div class="filter-group"><label>Marca</label><select id="f-marca"><option value="">Todas las Marcas</option></select></div>
            <div class="filter-group"><label>Línea</label><select id="f-linea"><option value="">Todas las Líneas</option></select></div>
            <div class="filter-group"><label>Serie</label><select id="f-serie"><option value="">Todas las Series</option></select></div>
            <button id="btn-excel">EXCEL</button>
        </div>

        <div class="paging">
            <button id="prev-page" class="nav-btn">Anterior</button>
            <span id="page-info">Iniciando catálogo...</span>
            <button id="next-page" class="nav-btn">Siguiente</button>
        </div>

        <div class="wrapper">
            <table>
                <thead>
                    <tr>
                        <th class="th-bordo" style="width: 220px;">MODELO</th>
                        <th class="th-bordo" style="width: 70px;">FOTO</th>
                        <th class="th-bordo" style="width: 100px;">MARCA</th>
                        <th class="th-bordo" style="width: 130px;">LINEA</th>
                        <th class="th-bordo" style="width: 180px;">SERIE</th>
                        <th class="th-negro" style="width: 250px;">CARAC. TÉCNICAS</th>
                        <th class="th-negro" style="width: 80px;">DIAMOND</th>
                        <th class="th-negro" style="width: 80px;">BLACK</th>
                        <th class="th-negro" style="width: 80px;">PLATINUM</th>
                        <th class="th-negro" style="width: 80px;">RUBY</th>
                        <th class="th-negro" style="width: 80px;">GOLD</th>
                        <th class="th-negro" style="width: 80px;">FOB BDM</th>
                        <th class="th-negro" style="width: 80px;">PROY BDM</th>
                        <th class="th-negro" style="width: 80px;">FOB DIR</th>
                        <th class="th-negro" style="width: 80px;">PROY DIR</th>
                        <th class="th-negro" style="width: 100px;">CICLO</th>
                        <th class="th-negro" style="width: 110px;">SAP CODE</th>
                    </tr>
                </thead>
                <tbody id="tabla-body"></tbody>
            </table>
        </div>
    </div>

    <script is:inline>
        const { createClient } = window.supabase;
        const _supabase = createClient('https://wmubdrjqailnizfyxsft.supabase.co', 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndtdWJkcmpxYWlsbml6Znl4c2Z0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njg5MjA5OTEsImV4cCI6MjA4NDQ5Njk5MX0.Wcc16V3KQGQnrG18o1aZuUDyP3BrqzI8_i0Dht6Qpc4');

        // LISTAS MAESTRAS (Para asegurar que aparezca TODO)
