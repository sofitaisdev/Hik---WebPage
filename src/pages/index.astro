function makeImageCell(val) {
  var d = document.createElement('div'); d.className = 'img-cell';
  var url = val ? String(val).trim() : '';
  if (!url || url === 'null' || url === 'undefined' || url.length < 5) {
    var ph = document.createElement('div'); ph.className = 'img-placeholder'; ph.textContent = 'Sin foto'; d.appendChild(ph); return d;
  }
  var img = document.createElement('img'); img.className = 'img-thumb';
  img.setAttribute('width', '48'); img.setAttribute('height', '48');
  img.src = url; img.alt = ''; img.loading = 'lazy';
  img.addEventListener('click', function() {
    document.getElementById('lightbox-img').src = url;
    document.getElementById('lightbox').classList.add('active');
  });
  img.addEventListener('error', function() {
    d.innerHTML = ''; var ph = document.createElement('div'); ph.className = 'img-placeholder'; ph.textContent = 'Sin foto'; d.appendChild(ph);
  });
  d.appendChild(img); return d;
}

/* ================================================================
   GENERIC CELL
================================================================ */
function makeCell(content, w, alignLeft, isFunciones, fullText) {
  var d = document.createElement('div');
  var jc = alignLeft ? 'flex-start' : 'center'; var ta = alignLeft ? 'left' : 'center';
  d.style.cssText = 'flex:0 0 ' + w + 'px;width:' + w + 'px;display:flex;align-items:' + (isFunciones ? 'flex-start' : 'center') + ';justify-content:' + jc + ';text-align:' + ta + ';padding:' + (isFunciones ? '6px 8px' : '5px 5px') + ';font-size:.72rem;box-sizing:border-box;overflow:hidden;border-right:1px solid #f0f0f0;height:100%;';
  if (isFunciones) {
    var inner = document.createElement('div');
    inner.className = 'func-cell';
    inner.textContent = typeof content === 'string' ? content : '';
    if (fullText) inner.title = fullText;
    d.appendChild(inner);
  } else {
    if (typeof content === 'string') d.innerHTML = content; else d.appendChild(content);
  }
  return d;
}

/* ================================================================
   RENDER TABLE ROWS
================================================================ */
function render() {
  var body = document.getElementById('table-body'); body.innerHTML = '';
  if (!currentData.length) {
    body.innerHTML = '<div style="text-align:center;padding:48px;color:#aaa;">No se encontraron productos.</div>'; return;
  }
  var cols = getVisibleColumns();
  var totalW = cols.reduce(function(a, c) { return a + c.w; }, 0);
  var frag = document.createDocumentFragment();
  currentData.forEach(function(p) {
    var row = document.createElement('div'); row.className = 'tbl-row';
    row.style.cssText = 'display:flex;width:' + totalW + 'px;min-width:' + totalW + 'px;border-bottom:1px solid #e8e8e8;height:60px;max-height:60px;overflow:hidden;align-items:center;';
    cols.forEach(function(col) {
      var val = p[col.field];
      if (col.image) { row.appendChild(makeImageCell(val)); return; }
      if (col.price) {
        var html = (val === undefined || val === null || val === '') ? "<span class='price p-zero'>-</span>" : formatPrice(val, col.cls);
        row.appendChild(makeCell(html, col.w, false, false, null)); return;
      }
      var isFunciones = !!col.funciones;
      var rawTxt = (val === undefined || val === null || val === '') ? '' : String(val).trim();
      var txt = rawTxt || '-';
      if (!isFunciones && txt.length > 140) txt = txt.substring(0, 140) + '...';
      row.appendChild(makeCell(txt, col.w, !!col.alignLeft, isFunciones, isFunciones ? rawTxt : null));
    });
    frag.appendChild(row);
  });
  body.appendChild(frag);
}

/* ================================================================
   PAGINATION
================================================================ */
function paginate() {
  var pages = Math.ceil(totalCount / PAGE_SIZE); var pag = document.getElementById('pagination');
  if (pages <= 1) { pag.innerHTML = "<span class='page-info'>" + totalCount + " productos</span>"; return; }
  var h = "<button class='page-btn' id='pp'" + (currentPage === 1 ? ' disabled' : '') + ">Anterior</button>";
  for (var i = 1; i <= pages; i++) {
    if (i === 1 || i === pages || Math.abs(i - currentPage) <= 2) h += "<button class='page-btn" + (i === currentPage ? ' active' : '') + "' data-p='" + i + "'>" + i + "</button>";
    else if (Math.abs(i - currentPage) === 3) h += "<span class='page-info'>...</span>";
  }
  h += "<button class='page-btn' id='pn'" + (currentPage === pages ? ' disabled' : '') + ">Siguiente</button>";
  h += "<span class='page-info'>Pág " + currentPage + "/" + pages + " — " + totalCount + " productos</span>";
  pag.innerHTML = h;
  var pp = document.getElementById('pp'); if (pp) pp.addEventListener('click', function() { doSearch(currentPage - 1); });
  var pn = document.getElementById('pn'); if (pn) pn.addEventListener('click', function() { doSearch(currentPage + 1); });
  pag.querySelectorAll('[data-p]').forEach(function(b) { b.addEventListener('click', function() { doSearch(+b.dataset.p); }); });
}

