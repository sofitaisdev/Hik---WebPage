async function fetchPricebook(){
  if(!PRICEBOOK_URL)return{};
  try{
    var res=await fetch(PRICEBOOK_URL,{cache:'no-store'});if(!res.ok)return{};
    var buf=await res.arrayBuffer();var wb=XLSX.read(buf,{type:'array'});
    var ws=wb.Sheets[wb.SheetNames[0]];var rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
    var header=rows[0].map(function(h){return String(h).trim().toLowerCase();});
    var sapIdx=header.indexOf('sap code'),funcIdx=header.indexOf('functional description');
    if(sapIdx===-1||funcIdx===-1)return{};
    var map={};
    for(var i=1;i<rows.length;i++){var sap=String(rows[i][sapIdx]).trim(),func=String(rows[i][funcIdx]).trim();if(sap&&func&&func!=='undefined')map[sap]=func;}
    return map;
  }catch(e){return{};}
}

async function fetchAllProducts(){
  var msgEl=document.getElementById('loading-msg');var all=[],offset=0,page=1;
  while(true){
    if(msgEl)msgEl.textContent='Cargando... página '+page+' ('+all.length+' productos)';
    var from=offset,to=offset+SB_PAGE-1;var authTok=sessionToken||SB_KEY;
    var res=await fetch(SB_URL+'/rest/v1/productos?select=*',
      {headers:{apikey:SB_KEY,Authorization:'Bearer '+authTok,'Content-Type':'application/json','Range-Unit':'items','Range':from+'-'+to,'Prefer':'count=exact'},cache:'no-store'});
    if(!res.ok){var eb='';try{eb=await res.text();}catch(e){}throw new Error('API '+res.status+(eb?': '+eb.substring(0,200):''));}
    var rows=await res.json();if(!Array.isArray(rows))rows=[];
    var cr=res.headers.get('content-range')||'';var tm=cr.match(/\/(\d+)$/);var serverTotal=tm?parseInt(tm[1],10):null;
    all=all.concat(rows);
    if(msgEl&&serverTotal)msgEl.textContent='Cargando... '+all.length+' / '+serverTotal+' productos';
    if(rows.length<SB_PAGE)break;if(serverTotal!==null&&all.length>=serverTotal)break;
    offset+=SB_PAGE;page++;await new Promise(function(r){setTimeout(r,50);});
  }
  all.forEach(function(p){p._score=completenessScore(p);});all.sort(function(a,b){return b._score-a._score;});return all;
}

